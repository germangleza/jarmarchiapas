        var item = btn.closest('.faq-item');
        var isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
        if (!isOpen) item.classList.add('open');
      });
    });

    // Conversión Google Ads en clics de WhatsApp (sin bloquear el clic)
    document.querySelectorAll('a[href*="wa.me"]').forEach(function(el) {
      el.addEventListener('click', function() {
        if (typeof gtag === 'function') {
          gtag('event', 'conversion', {
            send_to: 'AW-17977352986/zRKPCO6GotIcEJrGovxC',
            value: 1.0,
            currency: 'MXN'
          });
        }
      });
    });

    // Formulario → abre WhatsApp con los datos
    document.getElementById('empresaForm').addEventListener('submit', function(e) {
      e.preventDefault();
      var v = function(id) { return (document.getElementById(id).value || '').trim(); };
      var lineas = [
        'Hola, quiero llevar Jarmar a mi empresa.',
        '',
        'Nombre: ' + v('f-nombre'),
        'Empresa: ' + v('f-empresa'),
        'Puesto: ' + (v('f-puesto') || 'N/D'),
        'Ciudad: ' + v('f-ciudad'),
        'Colaboradores: ' + (v('f-colaboradores') || 'N/D'),
        'Teléfono: ' + v('f-telefono'),
        'Correo: ' + v('f-correo'),
        'Modalidad de interés: ' + (v('f-modalidad') || 'Por definir')
      ];
      if (typeof gtag === 'function') {
        gtag('event', 'conversion', {
          send_to: 'AW-17977352986/zRKPCO6GotIcEJrGovxC',
          value: 1.0,
          currency: 'MXN'
        });
      }
      window.open('https://wa.me/529611855475?text=' + encodeURIComponent(lineas.join('\n')), '_blank');
    });
  </script>

