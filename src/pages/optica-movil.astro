---
// Landing B2B: Jarmar en tu Empresa (óptica móvil)
// Ruta: /optica-movil
---
<!DOCTYPE html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>Jarmar en tu Empresa | Óptica Móvil para Empresas · Estudios Visuales en tus Instalaciones</title>
  <meta name="description" content="Llevamos nuestra óptica móvil a tu empresa: estudios visuales, asesoría y lentes con descuentos y facilidades de pago para tus colaboradores, sin salir del trabajo." />
  <link rel="canonical" href="https://jarmar.com/optica-movil/" />
  <meta property="og:title" content="Jarmar en tu Empresa | Óptica Móvil para Empresas" />
  <meta property="og:description" content="Salud visual para tu equipo, directamente en sus instalaciones. Estudios visuales, asesoría y lentes con beneficios exclusivos." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://jarmar.com/optica-movil/" />
  <meta property="og:image" content="https://jarmar.com/favicon.png" />
  <meta property="og:locale" content="es_MX" />
  <meta property="og:site_name" content="Ópticas Jarmar" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Google tag (gtag.js) -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-17977352986"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-17977352986');
