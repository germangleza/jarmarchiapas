---
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/LogoXS color.png" />
  <link rel="apple-touch-icon" href="/LogoXS color.png" />
  <title>Ópticas Jarmar | Clínica Óptica Boutique · México</title>
  <meta name="description" content="60 años cuidando la salud visual de México. Clínica Óptica Boutique con presencia en Chiapas y Tijuana. Diagnóstico médico, lentes graduados, Jarmar Eyewear y lentes esclerales." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    /* ═══════════════════════════════
       VARIABLES
    ═══════════════════════════════ */
    :root {
      --azul-noche:   #071A3E;
      --azul-oscuro:  #0D2B6B;
      --azul-medio:   #1A5BB5;
      --azul-claro:   #3A8FE0;
      --azul-hielo:   #C8DEFF;
      --azul-acento:  #3A8FE0;
      --azul-acento-suave: rgba(58,143,224,0.15);
      --blanco:       #FFFFFF;
      --crema:        #F7F9FC;
      --gris-suave:   #EDF1F8;
      --gris-texto:   #4A5568;
      --gris-claro:   #8899AA;

      --grad-hero:    linear-gradient(135deg, #071A3E 0%, #0D2B6B 50%, #1A5BB5 100%);
      --grad-azul:    linear-gradient(135deg, #1A5BB5 0%, #3A8FE0 100%);
      --grad-suave:   linear-gradient(180deg, #F8F6F2 0%, #EDF1F8 100%);

      --font-display: 'Playfair Display', Georgia, serif;
      --font-body:    'DM Sans', sans-serif;

      --radius:    20px;
      --radius-sm: 10px;
      --ease:      cubic-bezier(0.4, 0, 0.2, 1);
      --trans:     all 0.4s var(--ease);
      --sombra:    0 4px 30px rgba(7,26,62,0.12);
      --sombra-lg: 0 20px 60px rgba(7,26,62,0.22);
    }

    /* ═══════════════════════════════
       RESET
    ═══════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      color: var(--azul-noche);
      background: var(--blanco);
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }

    /* ═══════════════════════════════
       UTILITIES
    ═══════════════════════════════ */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 28px; }

    .tag {
      display: inline-block;
      font-family: var(--font-body);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 20px;
    }
    .tag--light { background: rgba(58,143,224,0.15); color: var(--azul-claro); }
    .tag--dark  { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.75); }
    .tag--blue  { background: rgba(26,91,181,0.1); color: var(--azul-medio); }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4.5vw, 3.4rem);
      font-weight: 600;
      line-height: 1.12;
      color: var(--azul-oscuro);
    }
    .section-title em { font-style: italic; color: var(--azul-medio); }
    .section-title--white { color: var(--blanco); }
    .section-title--white em { color: var(--azul-claro); }

    .section-sub {
      font-size: 1rem;
      color: var(--gris-texto);
      line-height: 1.75;
      max-width: 580px;
      margin-top: 14px;
    }
    .section-sub--white { color: rgba(255,255,255,0.7); }

    /* ═══════════════════════════════
       REVEAL ANIMATIONS
    ═══════════════════════════════ */
    .reveal       { opacity:0; transform: translateY(40px); transition: opacity .75s var(--ease), transform .75s var(--ease); }
    .reveal-l     { opacity:0; transform: translateX(-40px); transition: opacity .75s var(--ease), transform .75s var(--ease); }
    .reveal-r     { opacity:0; transform: translateX(40px); transition: opacity .75s var(--ease), transform .75s var(--ease); }
    .reveal.on, .reveal-l.on, .reveal-r.on { opacity:1; transform: none; }
    .d1 { transition-delay:.1s; } .d2 { transition-delay:.2s; }
    .d3 { transition-delay:.3s; } .d4 { transition-delay:.4s; }
    .d5 { transition-delay:.5s; }

    /* ═══════════════════════════════
       NAVBAR
    ═══════════════════════════════ */
    .nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 900;
      padding: 18px 0;
      transition: var(--trans);
    }
    .nav.scrolled {
      background: rgba(7,26,62,0.96);
      backdrop-filter: blur(16px);
      padding: 12px 0;
      box-shadow: 0 4px 30px rgba(7,26,62,0.3);
    }
    .nav-inner {
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo { display: flex; align-items: center; gap: 12px; }
    .nav-logo-mark {
      width: 48px; height: 48px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
    }
    .nav-logo-mark img { width: 100%; height: 100%; object-fit: contain; }
    .nav-logo-text strong { display: block; font-family: var(--font-display); font-size: 1rem; font-weight: 600; color: var(--blanco); line-height:1; }
    .nav-logo-text span   { font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.55); }
    .nav-links { display: flex; align-items: center; gap: 30px; }
    .nav-links a { font-size: 0.85rem; font-weight: 500; color: rgba(255,255,255,0.75); transition: color .3s; }
    .nav-links a:hover { color: var(--blanco); }
    .nav-cta {
      background: var(--grad-azul) !important;
      color: var(--azul-oscuro) !important;
      padding: 10px 22px;
      border-radius: 100px;
      font-weight: 700 !important;
      font-size: 0.82rem !important;
      transition: var(--trans) !important;
      box-shadow: 0 4px 16px rgba(58,143,224,0.3);
    }
    .nav-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(58,143,224,0.4) !important; }
    .nav-burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
    .nav-burger span { width: 24px; height: 2px; background: var(--blanco); border-radius: 2px; transition: var(--trans); }

    /* ═══════════════════════════════
       HERO
    ═══════════════════════════════ */
    .hero {
      position: relative;
      min-height: 100vh;
      background: var(--grad-hero);
      display: flex; align-items: center;
      overflow: hidden;
    }

    /* Mapa de México decorativo */
    .hero-map {
      position: absolute;
      right: -60px; top: 50%;
      transform: translateY(-50%);
      width: 620px; height: 620px;
      opacity: 0.06;
    }

    /* Línea diagonal decorativa */
    .hero-line { display: none; }

    /* Orbes de luz */
    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(90px);
      animation: drift 12s ease-in-out infinite;
    }
    .orb-1 { width: 500px; height: 500px; background: #1A5BB5; opacity: .18; top: -80px; right: 100px; }
    .orb-2 { width: 300px; height: 300px; background: #3A8FE0; opacity: .12; bottom: -40px; right: 300px; animation-delay: -6s; }
    .orb-3 { width: 200px; height: 200px; background: #3A8FE0; opacity: .15; top: 30%; left: -40px; animation-delay: -3s; }
    @keyframes drift { 0%,100%{transform:translate(0,0);}33%{transform:translate(20px,-15px);}66%{transform:translate(-10px,20px);} }

    .hero-inner {
      position: relative; z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 130px 60px 90px;
      max-width: 800px;
      margin: 0 auto;
    }

    /* Etiqueta de país */
    .hero-country {
      display: inline-flex; align-items: center; gap: 10px;
      background: rgba(58,143,224,0.1);
      border: 1px solid rgba(58,143,224,0.25);
      backdrop-filter: blur(6px);
      padding: 8px 18px;
      border-radius: 100px;
      margin-bottom: 28px;
    }
    .hero-country-dot { width: 7px; height: 7px; background: var(--azul-claro); border-radius: 50%; animation: blink 2s ease-in-out infinite; }
    @keyframes blink { 0%,100%{opacity:1;}50%{opacity:.3;} }
    .hero-country span { font-size: 0.75rem; color: rgba(58,143,224,0.6); letter-spacing: 0.15em; font-weight: 500; text-transform: uppercase; }

    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(3rem, 6vw, 5.2rem);
      font-weight: 600;
      color: var(--blanco);
      line-height: 1.0;
      margin-bottom: 28px;
    }
    .hero-headline em {
      font-style: italic;
      color: var(--azul-claro);
    }
    .hero-headline .small {
      display: block;
      font-size: clamp(1.2rem, 2.2vw, 1.8rem);
      font-weight: 400;
      color: rgba(255,255,255,0.6);
      letter-spacing: 0.06em;
      margin-bottom: 8px;
      font-style: normal;
    }

    .hero-sub {
      font-size: 1.05rem;
      color: rgba(255,255,255,0.72);
      line-height: 1.78;
      max-width: 500px;
      margin-bottom: 40px;
    }

    .hero-route {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 40px;
    }
    .route-city {
      display: flex; flex-direction: column;
      align-items: center;
    }
    .route-city strong { font-family: var(--font-display); font-size: 1rem; color: var(--blanco); font-weight: 600; }
    .route-city span   { font-size: 0.65rem; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: 0.12em; margin-top: 2px; }
    .route-line {
      flex: 1;
      position: relative;
      height: 2px;
      background: rgba(58,143,224,0.2);
      border-radius: 2px;
      overflow: visible;
    }
    .route-traveler {
      position: absolute;
      top: 50%; transform: translateY(-50%);
      width: 10px; height: 10px;
      background: var(--azul-claro);
      border-radius: 50%;
      box-shadow: 0 0 8px rgba(58,143,224,0.7), 0 0 0 3px rgba(58,143,224,0.2);
      animation: travel 2.8s ease-in-out infinite;
    }
    @keyframes travel {
      0%   { left: 0%; opacity: 0; }
      10%  { opacity: 1; }
      50%  { left: calc(100% - 10px); }
      90%  { opacity: 1; }
      100% { left: 0%; opacity: 0; }
    }

    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }

    .btn-gold {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--grad-azul);
      color: var(--azul-oscuro);
      padding: 16px 32px;
      border-radius: 100px;
      font-weight: 700; font-size: 0.92rem;
      transition: var(--trans);
      box-shadow: 0 6px 24px rgba(58,143,224,0.35);
    }
    .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 10px 32px rgba(58,143,224,0.5); }

    .btn-ghost {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent;
      color: rgba(255,255,255,0.85);
      padding: 16px 28px;
      border-radius: 100px;
      font-weight: 500; font-size: 0.92rem;
      border: 1.5px solid rgba(255,255,255,0.25);
      transition: var(--trans);
    }
    .btn-ghost:hover { border-color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.07); }

    /* Stats hero */
    .hero-stats {
      display: flex; gap: 0;
      margin-top: 52px;
      padding-top: 40px;
      border-top: 1px solid rgba(255,255,255,0.1);
    }
    .hero-stat { flex: 1; padding-right: 28px; border-right: 1px solid rgba(255,255,255,0.08); }
    .hero-stat:last-child { border-right: none; padding-left: 28px; padding-right: 0; }
    .hero-stat:first-child { padding-left: 0; }
    .hero-stat strong { display: block; font-family: var(--font-display); font-size: 2.2rem; color: var(--azul-claro); line-height: 1; }
    .hero-stat span   { font-size: 0.72rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 5px; display: block; }

    /* Hero visual lado derecho */
    .hero-visual { display: none; }
    .hero-frame {
      position: relative;
      border-radius: 28px;
      overflow: hidden;
      aspect-ratio: 3/4;
      box-shadow: var(--sombra-lg);
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
    }
    .hero-frame img { width:100%; height:100%; object-fit: cover; }
    .hero-placeholder {
      width:100%; height:100%;
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px;
      color: rgba(255,255,255,0.25);
      font-size: 0.82rem;
      text-align: center; padding: 24px;
    }
    .hero-placeholder svg { opacity: .35; }

    /* Tarjeta flotante años */
    .hero-badge-float {
      position: absolute;
      bottom: -20px; left: -28px;
      background: var(--grad-azul);
      border-radius: 18px;
      padding: 20px 24px;
      box-shadow: 0 8px 32px rgba(58,143,224,0.4);
      min-width: 150px;
    }
    .hero-badge-float strong { display: block; font-family: var(--font-display); font-size: 2.4rem; color: var(--azul-oscuro); line-height: 1; }
    .hero-badge-float span   { font-size: 0.72rem; font-weight: 700; color: var(--azul-oscuro); text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.7; }

    /* ═══════════════════════════════
       SELECTOR CIUDADES
    ═══════════════════════════════ */
    .ciudades {
      padding: 110px 0;
      background: #F7F9FC;
      position: relative;
      overflow: hidden;
    }
    .ciudades::before {
      content: '';
      position: absolute;
      top: -1px; left: 0; right: 0;
      height: 80px;
      background: linear-gradient(180deg, var(--azul-noche) 0%, transparent 100%);
    }
    .ciudades-header { text-align: center; margin-bottom: 60px; }
    .ciudades-header .section-sub { margin: 14px auto 0; }

    .ciudades-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }

    a.ciudad-card { text-decoration: none; color: inherit; display: block; cursor: pointer; }
    .ciudad-card {
      position: relative;
      border-radius: 28px;
      overflow: hidden;
      cursor: pointer;
      transition: var(--trans);
      box-shadow: var(--sombra);
      group: true;
    }
    .ciudad-card:hover { transform: translateY(-8px); box-shadow: var(--sombra-lg); }

    .ciudad-img {
      aspect-ratio: 16/10;
      background: var(--grad-hero);
      position: relative;
      overflow: hidden;
    }
    .ciudad-img-placeholder {
      width: 100%; height: 100%;
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px;
      color: rgba(255,255,255,0.25); font-size: 0.8rem; text-align: center;
      min-height: 220px;
    }
    .ciudad-img img { width:100%; height:100%; object-fit:cover; transition: transform .6s var(--ease); }
    .ciudad-card:hover .ciudad-img img { transform: scale(1.05); }

    .ciudad-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(180deg, transparent 30%, rgba(7,26,62,0.85) 100%);
    }
    .ciudad-overlay-text {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 28px;
    }
    .ciudad-tag-city {
      display: inline-block;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--azul-claro);
      background: rgba(58,143,224,0.15);
      border: 1px solid rgba(58,143,224,0.3);
      padding: 4px 12px;
      border-radius: 100px;
      margin-bottom: 10px;
    }
    .ciudad-overlay-text h3 {
      font-family: var(--font-display);
      font-size: 1.8rem;
      font-weight: 600;
      color: var(--blanco);
      line-height: 1.1;
    }
    .ciudad-overlay-text p {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.65);
      margin-top: 4px;
    }

    .ciudad-body {
      background: var(--blanco);
      padding: 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }
    .ciudad-info strong {
      display: block;
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--azul-oscuro);
      margin-bottom: 4px;
    }
    .ciudad-info span { font-size: 0.78rem; color: var(--gris-claro); }

    .ciudad-btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--azul-oscuro);
      color: var(--blanco);
      padding: 12px 22px;
      border-radius: 100px;
      font-size: 0.82rem;
      font-weight: 600;
      transition: var(--trans);
      white-space: nowrap;
      flex-shrink: 0;
    }
    .ciudad-btn:hover { background: var(--azul-medio); }

    .ciudad-btn-placeholder {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--gris-suave);
      color: var(--gris-claro);
      padding: 12px 22px;
      border-radius: 100px;
      font-size: 0.82rem;
      font-weight: 600;
      flex-shrink: 0;
      cursor: default;
    }

    .ciudad-coming {
      position: absolute;
      top: 20px; right: 20px;
      background: rgba(58,143,224,0.9);
      backdrop-filter: blur(6px);
      color: var(--azul-oscuro);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 6px 14px;
      border-radius: 100px;
    }

    /* ═══════════════════════════════
       CONCEPTO (3 PILARES)
    ═══════════════════════════════ */
    .concepto {
      padding: 110px 0;
      background: var(--grad-hero);
      position: relative;
      overflow: hidden;
    }
    .concepto::before { display: none; }
    .concepto .container { position: relative; z-index: 2; }
    .concepto-inner {
      display: grid;
      grid-template-columns: 1fr 1.8fr;
      gap: 80px;
      align-items: center;
    }
    .concepto-left { position: sticky; top: 100px; }
    .concepto-left .section-sub--white { margin-top: 16px; }

    .concepto-divider {
      width: 48px; height: 2px;
      background: var(--grad-azul);
      margin: 24px 0;
      border-radius: 2px;
    }
    .concepto-number {
      font-family: var(--font-display);
      font-size: 8rem;
      font-weight: 600;
      color: rgba(255,255,255,0.04);
      line-height: 1;
      margin-top: 20px;
    }

    .pilares { display: flex; flex-direction: column; gap: 24px; }
    .pilar {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 20px;
      padding: 32px;
      transition: var(--trans);
      position: relative;
      overflow: hidden;
    }
    .pilar:hover { background: rgba(255,255,255,0.09); border-color: rgba(58,143,224,0.25); }
    .pilar::before {
      content: '';
      position: absolute; left: 0; top: 0; bottom: 0;
      width: 3px;
      background: var(--grad-azul);
      opacity: 0;
      transition: var(--trans);
    }
    .pilar:hover::before { opacity: 1; }

    .pilar-head { display: flex; align-items: center; gap: 16px; margin-bottom: 14px; }
    .pilar-icon {
      width: 48px; height: 48px;
      background: rgba(58,143,224,0.12);
      border: 1px solid rgba(58,143,224,0.25);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display);
      font-size: 1.2rem; font-weight: 700;
      color: var(--azul-claro);
      flex-shrink: 0;
    }
    .pilar h3 { font-family: var(--font-display); font-size: 1.4rem; font-weight: 600; color: var(--blanco); }
    .pilar p  { font-size: 0.9rem; color: rgba(255,255,255,0.6); line-height: 1.75; }
    .pilar-list { margin-top: 14px; display: flex; flex-direction: column; gap: 7px; }
    .pilar-list li {
      list-style: none;
      font-size: 0.82rem;
      color: rgba(255,255,255,0.5);
      display: flex; align-items: center; gap: 8px;
    }
    .pilar-list li::before { content: '—'; color: var(--azul-claro); font-size: 0.7rem; }

    /* ═══════════════════════════════
       SERVICIOS
    ═══════════════════════════════ */
    .servicios {
      padding: 110px 0;
      background: var(--blanco);
    }
    .servicios-header { text-align: center; margin-bottom: 60px; }
    .servicios-header .section-sub { margin: 14px auto 0; }

    .servicios-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .servicio {
      background: var(--gris-suave);
      border-radius: 20px;
      padding: 32px 26px;
      text-align: center;
      transition: var(--trans);
      border: 1px solid transparent;
      position: relative;
      overflow: hidden;
    }
    .servicio::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: var(--grad-azul);
      transform: scaleX(0);
      transition: var(--trans);
    }
    .servicio:hover { background: var(--blanco); border-color: rgba(26,91,181,0.12); transform: translateY(-4px); box-shadow: var(--sombra); }
