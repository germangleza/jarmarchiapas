    .servicio p  { font-size: 1.05rem; color: var(--gris-texto); line-height: 1.65; }

    /* ═══════════════════════════════
       PRODUCTO ESTRELLA — ESCLERALES
    ═══════════════════════════════ */
    .estrella {
      padding: 110px 0;
      background: #F7F9FC;
      position: relative;
      overflow: hidden;
    }
    .estrella-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .estrella-img {
      position: relative;
      border-radius: 28px;
      overflow: hidden;
      aspect-ratio: 1/1;
      background: var(--grad-hero);
      box-shadow: var(--sombra-lg);
    }
    .estrella-img img { width:100%; height:100%; object-fit:cover; }
    .estrella-placeholder {
      width:100%; height:100%;
      display: flex; flex-direction:column; align-items:center; justify-content:center; gap:12px;
      color:rgba(255,255,255,0.25); font-size:0.82rem; text-align:center;
    }
    .estrella-badge {
      position: absolute;
      top: 24px; left: 24px;
      background: var(--grad-azul);
      color: var(--azul-oscuro);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 8px 16px;
      border-radius: 100px;
    }
    .estrella-years {
      position: absolute;
      bottom: 24px; right: 24px;
      background: rgba(7,26,62,0.85);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(58,143,224,0.25);
      border-radius: 16px;
      padding: 16px 20px;
      text-align: center;
    }
    .estrella-years strong { display:block; font-family:var(--font-display); font-size:2rem; color:var(--azul-claro); line-height:1; }
    .estrella-years span   { font-size:0.65rem; color:rgba(255,255,255,0.55); text-transform:uppercase; letter-spacing:0.12em; }

    .estrella-content .tag { margin-bottom: 16px; }
    .estrella-content .section-title { margin-bottom: 20px; }
    .estrella-content .section-sub { margin-top: 0; margin-bottom: 28px; }

    .estrella-puntos { display: flex; flex-direction: column; gap: 14px; margin-bottom: 36px; }
    .estrella-punto {
      display: flex; align-items: flex-start; gap: 14px;
      background: var(--blanco);
      border-radius: var(--radius-sm);
      padding: 14px 18px;
      border-left: 3px solid var(--azul-claro);
      box-shadow: 0 2px 12px rgba(7,26,62,0.06);
      transition: var(--trans);
    }
    .estrella-punto:hover { transform: translateX(4px); box-shadow: var(--sombra); }
    .estrella-punto-icon { font-size: 1.2rem; flex-shrink:0; margin-top:1px; }
    .estrella-punto p { font-size: 0.9rem; color: var(--gris-texto); line-height: 1.6; }

    .btn-azul {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--azul-oscuro);
      color: var(--blanco);
      padding: 16px 30px;
      border-radius: 100px;
      font-weight: 600; font-size: 0.9rem;
      transition: var(--trans);
      box-shadow: 0 4px 20px rgba(13,43,107,0.3);
    }
    .btn-azul:hover { background: var(--azul-medio); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(13,43,107,0.4); }

    /* ═══════════════════════════════
       TESTIMONIOS
    ═══════════════════════════════ */
    .testimonios {
      padding: 110px 0;
      background: var(--azul-noche);
      position: relative;
      overflow: hidden;
    }
    .testimonios::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 60% 50% at 20% 60%, rgba(26,91,181,0.15) 0%, transparent 70%);
    }
    .testimonios .container { position: relative; z-index: 2; }
    .testimonios-header { text-align: center; margin-bottom: 60px; }
    .testimonios-header .section-sub--white { margin: 14px auto 0; }

    .testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .testi {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 20px;
      padding: 28px 24px;
      transition: var(--trans);
      position: relative;
    }
    .testi:hover { background: rgba(255,255,255,0.09); border-color: rgba(58,143,224,0.2); transform: translateY(-4px); }
    .testi-stars { color: var(--azul-claro); font-size: 0.8rem; letter-spacing: 2px; margin-bottom: 14px; }
    .testi-ciudad {
      display: inline-block;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--azul-claro);
      background: rgba(58,143,224,0.1);
      border: 1px solid rgba(58,143,224,0.2);
      padding: 3px 10px;
      border-radius: 100px;
      margin-bottom: 14px;
    }
    .testi p { font-size: 0.88rem; color: rgba(255,255,255,0.65); line-height: 1.75; margin-bottom: 20px; font-style: italic; }
    .testi-autor { display: flex; align-items: center; gap: 12px; }
    .testi-av {
      width: 40px; height: 40px;
      background: linear-gradient(135deg, var(--azul-medio), var(--azul-claro));
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display);
      font-size: 0.9rem; font-weight: 600;
      color: var(--blanco);
      flex-shrink: 0;
    }
    .testi-av--gold { background: var(--grad-azul); color: var(--azul-oscuro); }
    .testi-info strong { font-size: 0.85rem; color: var(--blanco); display: block; }
    .testi-info span   { font-size: 0.75rem; color: rgba(255,255,255,0.4); }

    /* ═══════════════════════════════
       CTA FINAL
    ═══════════════════════════════ */
    .cta {
      padding: 110px 0;
      background: #F7F9FC;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta::before {
      content: '60';
      position: absolute;
      font-family: var(--font-display);
      font-size: 26rem;
      font-weight: 700;
      color: rgba(13,43,107,0.04);
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      white-space: nowrap;
      pointer-events: none;
      line-height: 1;
    }
    .cta .container { position: relative; z-index: 2; }
    .cta .section-title { margin: 16px 0; }
    .cta .section-sub { margin: 0 auto 40px; }
    .cta-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

    .btn-outline-azul {
      display: inline-flex; align-items: center; gap: 8px;
      border: 2px solid var(--azul-oscuro);
      color: var(--azul-oscuro);
      padding: 15px 28px;
      border-radius: 100px;
      font-weight: 600; font-size: 0.9rem;
      transition: var(--trans);
    }
    .btn-outline-azul:hover { background: var(--azul-oscuro); color: var(--blanco); }

    /* ═══════════════════════════════
       FOOTER
    ═══════════════════════════════ */
    footer {
      background: #040F25;
      padding: 64px 0 28px;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
      gap: 48px;
      padding-bottom: 48px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      margin-bottom: 28px;
    }
    .footer-brand .nav-logo { margin-bottom: 16px; }
    .footer-brand p { font-size: 0.83rem; color: rgba(255,255,255,0.4); line-height: 1.75; max-width: 280px; }
    .footer-col h5 {
      font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.16em;
      color: rgba(255,255,255,0.35);
      margin-bottom: 16px;
    }
    .footer-col ul { list-style:none; display:flex; flex-direction:column; gap:10px; }
    .footer-col ul li a { font-size: 0.83rem; color: rgba(255,255,255,0.5); transition: color .3s; }
    .footer-col ul li a:hover { color: var(--blanco); }
    .footer-col .footer-city {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--azul-claro);
      opacity: 0.7;
      margin-top: 14px;
      margin-bottom: 8px;
    }
    .footer-bottom {
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 12px;
    }
    .footer-bottom p { font-size: 0.75rem; color: rgba(255,255,255,0.25); }
    .footer-social { display: flex; gap: 20px; align-items: flex-start; }
    .footer-social-group { display: flex; flex-direction: column; gap: 6px; }
    .footer-social-label { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.3); }
    .footer-social-icons { display: flex; gap: 8px; }
    .social-ico {
      width: 34px; height: 34px;
      background: rgba(255,255,255,0.06);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: rgba(255,255,255,0.5);
      transition: var(--trans);
    }
    .social-ico svg { width: 16px; height: 16px; fill: currentColor; }
    .social-ico:hover { background: var(--azul-medio); color: var(--blanco); }
    .footer-link-row { display: flex; align-items: center; gap: 8px; }
    .footer-link-row svg { width: 13px; height: 13px; fill: none; stroke: currentColor; stroke-width: 1.8; flex-shrink: 0; opacity: 0.5; }

    /* ═══════════════════════════════
       WHATSAPP FLOAT
    ═══════════════════════════════ */
    .wa {
      position: fixed;
      bottom: 28px; right: 28px;
      z-index: 999;
      display: flex; align-items: center; gap: 12px;
    }
    .wa-tip {
      background: var(--azul-oscuro);
      color: var(--blanco);
      font-size: 0.78rem; font-weight: 600;
      padding: 9px 16px;
      border-radius: 100px;
      white-space: nowrap;
      box-shadow: var(--sombra);
      opacity: 0;
      transform: translateX(10px);
      transition: var(--trans);
      pointer-events: none;
    }
    .wa:hover .wa-tip { opacity:1; transform:translateX(0); }
    .wa-btn {
      width: 60px; height: 60px;
      background: #25D366;
      border-radius: 50%;
      display: flex; align-items:center; justify-content:center;
      box-shadow: 0 6px 24px rgba(37,211,102,0.45);
      transition: var(--trans);
      animation: wa-ring 3.5s ease-in-out infinite;
      flex-shrink: 0;
    }
    .wa-btn:hover { transform: scale(1.1); }
    @keyframes wa-ring {
      0%,100%{ box-shadow: 0 6px 24px rgba(37,211,102,0.45); }
      50%{ box-shadow: 0 6px 24px rgba(37,211,102,0.45), 0 0 0 14px rgba(37,211,102,0.1); }
    }

    /* ═══ HEX-BG ═══ */
    .hex-bg { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 1; }
    .hex-bg svg { position: absolute; }
    .hex-1  { top: 6%;  left: 3%;   opacity: 0.07; animation: float 10s ease-in-out infinite; }
    .hex-2  { top: 20%; right: 8%;  opacity: 0.06; animation: float 13s ease-in-out infinite reverse; }
    .hex-3  { top: 60%; left: 12%;  opacity: 0.05; animation: float 11s ease-in-out infinite 2s; }
    .hex-4  { top: 75%; right: 5%;  opacity: 0.08; animation: float 9s ease-in-out infinite 1s; }
    .hex-5  { top: 40%; left: 50%;  opacity: 0.04; animation: float 14s ease-in-out infinite 3s; }
    .hex-6  { top: 10%; right: 35%; opacity: 0.05; animation: float 12s ease-in-out infinite 0.5s; }
    @keyframes float { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-18px);} }

    /* ═══════════════════════════════
       RESPONSIVE
    ═══════════════════════════════ */
    @media (max-width: 1024px) {
      .hero-inner    { grid-template-columns: 1fr; gap: 48px; }
      .hero-visual   { display: none; }
      .concepto-inner { grid-template-columns: 1fr; gap: 48px; }
      .concepto-left { position: static; }
      .estrella-inner { grid-template-columns: 1fr; gap: 48px; }
      .ciudades-grid { gap: 20px; }
      .servicios-grid { grid-template-columns: repeat(2,1fr); }
      .testi-grid { grid-template-columns: 1fr 1fr; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-burger { display: flex; }
      .nav-links.open {
        display: flex; flex-direction: column;
        position: fixed; inset: 0;
        background: rgba(7,26,62,0.98);
        backdrop-filter: blur(12px);
        align-items: center; justify-content: center;
        gap: 32px; z-index: 999;
      }
      .nav-links.open a { font-size: 1.2rem; }
      .ciudades-grid { grid-template-columns: 1fr; }
      .servicios-grid { grid-template-columns: 1fr; }
      .testi-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; gap: 32px; }
      .hero-stats { flex-wrap: wrap; gap: 20px; }
      .hero-stat { border-right: none; padding: 0; flex: 0 0 calc(50% - 10px); }
      .hero-actions { flex-direction: column; }
      .btn-gold, .btn-ghost { justify-content: center; }
      .cta-actions { flex-direction: column; align-items: center; }
    }
  </style>
</head>
