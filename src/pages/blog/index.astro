---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../../site.config.mjs";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d) =>
  new Intl.DateTimeFormat(site.lang, {
    day: "numeric",
    month: "short",
    year: "numeric",
  }).format(d);
---

<BaseLayout title={`Blog — ${site.name}`}>
  <div class="blog-hero">
    <span class="eyebrow">Blog</span>
    <h1>Salud visual, consejos<br />y novedades Jarmar</h1>
    <p>{site.description}</p>
  </div>

  <section class="wrap">
    <ul class="post-list">
      {
        posts.map((post) => (
          <li class="post-item">
            <a
              class="post-thumb-link"
              href={`/blog/${post.id}/`}
              tabindex="-1"
              aria-hidden="true"
            >
              <figure class="post-thumb">
                <img
                  src={post.data.image ?? `/blog/${post.id}.jpg`}
                  alt={post.data.title}
                  width="1600"
                  height="900"
                  loading="lazy"
                  onerror="this.closest('.post-thumb').classList.add('post-thumb--empty'); this.remove();"
                />
              </figure>
            </a>
            <div class="post-item-text">
              <span class="post-meta">{fmt(post.data.pubDate)}</span>
              <h2>
                <a class="post-title-link" href={`/blog/${post.id}/`}>
                  {post.data.title}
                </a>
              </h2>
              <p>{post.data.description}</p>
            </div>
          </li>
        ))
      }
      {
        posts.length === 0 && (
          <li style="color:var(--muted);padding:40px 0">
            Aún no hay artículos publicados.
          </li>
        )
      }
    </ul>
  </section>
</BaseLayout>
