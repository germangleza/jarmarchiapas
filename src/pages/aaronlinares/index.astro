<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/LogoXS color.png" />
  <title>Opt. Aarón Linares · Ópticas Jarmar</title>
  <meta name="description" content="Optometrista en Ópticas Jarmar. Sucursales en Tuxtla Gutiérrez y Tijuana." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --azul-noche:  #071A3E;
      --azul-oscuro: #0D2B6B;
      --azul-medio:  #1A5BB5;
      --azul-claro:  #3A8FE0;
      --blanco:      #FFFFFF;
      --crema:       #F7F9FC;
      --gris-texto:  #4A5568;
      --gris-suave:  #EDF1F8;
      --grad-hero:   linear-gradient(135deg, #071A3E 0%, #0D2B6B 55%, #1A5BB5 100%);
      --grad-azul:   linear-gradient(135deg, #1A5BB5 0%, #3A8FE0 100%);
      --font-display:'Playfair Display', Georgia, serif;
      --font-body:   'DM Sans', sans-serif;
      --radius:      20px;
      --ease:        cubic-bezier(0.4, 0, 0.2, 1);
      --trans:       all 0.4s var(--ease);
      --sombra:      0 4px 30px rgba(7,26,62,0.12);
      --sombra-lg:   0 20px 60px rgba(7,26,62,0.20);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      color: var(--azul-noche);
      background: var(--crema);
      min-height: 100vh;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }

    /* ─── NAVBAR ─── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 900; padding: 18px 0; transition: var(--trans);
    }
    .nav.scrolled {
      background: rgba(7,26,62,0.96);
      backdrop-filter: blur(16px);
      padding: 12px 0;
      box-shadow: 0 4px 30px rgba(7,26,62,0.3);
    }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .nav-logo { display: flex; align-items: center; gap: 12px; }
    .nav-logo-mark {
      width: 48px; height: 48px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden; flex-shrink: 0;
    }
    .nav-logo-mark img { width: 100%; height: 100%; object-fit: contain; }
    .nav-logo-text strong { display: block; font-family: var(--font-display); font-size: 1rem; font-weight: 600; color: var(--blanco); line-height: 1; }
    .nav-logo-text span { font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.55); }
    .nav-links { display: flex; align-items: center; gap: 30px; }
    .nav-links a { font-size: 0.85rem; font-weight: 500; color: rgba(255,255,255,0.75); transition: color .3s; text-decoration: none; }
    .nav-links a:hover { color: var(--blanco); }
    .nav-cta {
      background: var(--grad-azul) !important;
      color: var(--blanco) !important;
      padding: 10px 22px; border-radius: 100px;
      font-weight: 700 !important; font-size: 0.82rem !important;
      transition: var(--trans) !important;
      box-shadow: 0 4px 16px rgba(58,143,224,0.3);
    }
    .nav-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(58,143,224,0.4) !important; }
    .nav-burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
    .nav-burger span { width: 24px; height: 2px; background: var(--blanco); border-radius: 2px; transition: var(--trans); }
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-burger { display: flex; }
      .nav-links.open {
        display: flex; flex-direction: column;
        position: fixed; inset: 0;
        background: rgba(7,26,62,0.98);
        backdrop-filter: blur(12px);
        align-items: center; justify-content: center;
        gap: 32px; z-index: 999;
      }
      .nav-links.open a { font-size: 1.2rem; }
    }

    /* ─── HEADER ─── */
    .header {
      background: var(--grad-hero);
      padding: 100px 28px 80px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    /* hex-bg decorativo */
    .hex-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
    .hex { position: absolute; opacity: 0.06; }
    .hex svg { fill: currentColor; color: #3A8FE0; }
    .hex-1 { width: 220px; top: -40px; left: -60px; animation: float 9s ease-in-out infinite; }
    .hex-2 { width: 160px; top: 20px; right: 40px; animation: float 11s ease-in-out infinite reverse; }
    .hex-3 { width: 100px; bottom: 20px; left: 30%; animation: float 8s ease-in-out infinite 2s; }
    @keyframes float {
      0%,100% { transform: translateY(0) rotate(0deg); }
      50%      { transform: translateY(-18px) rotate(6deg); }
    }

    /* Logo Jarmar arriba */
    .header-brand {
      display: flex; align-items: center; justify-content: space-between; gap: 10px;
      margin-bottom: 48px;
    }
    .header-brand-blog {
      font-size: 0.82rem; font-weight: 500; color: rgba(255,255,255,0.75);
      text-decoration: none; transition: color .2s;
    }
    .header-brand-blog:hover { color: #fff; }
    .header-brand img { width: 40px; height: 40px; object-fit: contain; }
    .header-brand-text { text-align: left; }
    .header-brand-text strong { display: block; font-family: var(--font-display); font-size: 0.9rem; color: var(--blanco); line-height: 1; }
    .header-brand-text span { font-size: 0.58rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.5); }

    /* Foto circular */
    .avatar-wrap {
      position: relative;
      display: inline-block;
      margin-bottom: 28px;
    }
    .avatar {
      width: 150px; height: 150px;
      border-radius: 50%;
      background: rgba(255,255,255,0.12);
      border: 3px solid rgba(255,255,255,0.25);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto;
      overflow: hidden;
    }
    .avatar img { width: 100%; height: 100%; object-fit: cover; }
    .avatar-placeholder {
      display: flex; flex-direction: column; align-items: center; gap: 8px;
    }
    .avatar-placeholder svg { opacity: 0.4; }
    .avatar-placeholder span { font-size: 0.62rem; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); text-transform: uppercase; }

    /* Badge cargo */
    .cargo-badge {
      display: inline-block;
      background: rgba(58,143,224,0.25);
      border: 1px solid rgba(58,143,224,0.4);
      color: #90C4F0;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 5px 14px;
      border-radius: 100px;
      margin-bottom: 14px;
    }

    .header-name {
      font-family: var(--font-display);
      font-size: clamp(1.7rem, 5vw, 2.6rem);
      font-weight: 600;
      color: var(--blanco);
      line-height: 1.15;
      margin-bottom: 20px;
    }

    .header-sub {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.6);
      font-weight: 300;
      letter-spacing: 0.04em;
      margin-bottom: 24px;
    }

    /* Teléfono personal */
    .header-phone {
      display: inline-flex; align-items: center; gap: 10px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 100px;
      padding: 12px 24px;
      color: var(--blanco);
      font-size: 1.05rem;
      font-weight: 500;
      transition: var(--trans);
    }
    .header-phone:hover {
      background: rgba(255,255,255,0.14);
      transform: translateY(-2px);
    }
    .header-phone svg { flex-shrink: 0; }

    /* Ondas decorativas abajo del header */
    .header-wave {
      position: absolute;
      bottom: -1px; left: 0; right: 0;
    }

    /* ─── SUCURSALES ─── */
    .sucursales {
      padding: 64px 28px 80px;
      max-width: 900px;
      margin: 0 auto;
    }
    .suc-titulo {
      text-align: center;
      margin-bottom: 48px;
    }
    .suc-titulo .tag {
      display: inline-block;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      background: rgba(26,91,181,0.1);
      color: var(--azul-medio);
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 16px;
    }
    .suc-titulo h2 {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 3.5vw, 2.2rem);
      font-weight: 600;
      color: var(--azul-oscuro);
      line-height: 1.2;
    }

    .suc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 24px;
    }

    .suc-card {
      background: var(--blanco);
      border-radius: var(--radius);
      box-shadow: var(--sombra);
      overflow: hidden;
      transition: var(--trans);
    }
    .suc-card:hover { transform: translateY(-6px); box-shadow: var(--sombra-lg); }

    .suc-card-header {
      background: var(--grad-hero);
      padding: 22px 24px 18px;
      position: relative;
      overflow: hidden;
    }
    .suc-city {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.55);
      margin-bottom: 4px;
    }
    .suc-name {
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--blanco);
      line-height: 1.25;
    }
    .suc-num {
      position: absolute;
      top: 14px; right: 20px;
      font-family: var(--font-display);
      font-size: 2.2rem;
      font-weight: 700;
      color: rgba(255,255,255,0.08);
      line-height: 1;
    }

    .suc-card-body { padding: 22px 24px 20px; }

    .suc-address {
      display: flex; gap: 10px; align-items: flex-start;
      margin-bottom: 18px;
    }
    .suc-address svg { flex-shrink: 0; margin-top: 2px; color: var(--azul-claro); }
    .suc-address p { font-size: 0.88rem; color: var(--gris-texto); line-height: 1.55; }

    .suc-actions { display: flex; flex-direction: column; gap: 10px; }

    .btn-maps {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      background: var(--grad-azul);
      color: var(--blanco);
      font-size: 0.82rem;
      font-weight: 600;
      padding: 11px 18px;
      border-radius: 10px;
      transition: var(--trans);
    }
    .btn-maps:hover { opacity: 0.9; transform: translateY(-1px); }

    .btn-tel {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      background: var(--gris-suave);
      color: var(--azul-oscuro);
      font-size: 0.82rem;
      font-weight: 600;
      padding: 11px 18px;
      border-radius: 10px;
      transition: var(--trans);
    }
    .btn-tel:hover { background: #dce6f5; transform: translateY(-1px); }

    /* ─── FOOTER ─── */
    .footer {
      background: var(--azul-noche);
      padding: 32px 28px;
      text-align: center;
    }
    .footer-logo {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      margin-bottom: 12px;
    }
    .footer-logo img { width: 34px; height: 34px; object-fit: contain; }
    .footer-logo span { font-family: var(--font-display); font-size: 0.9rem; color: var(--blanco); }
    .footer p {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.35);
    }

    /* ─── REVEAL ─── */
    .reveal { opacity:0; transform: translateY(30px); transition: opacity .7s var(--ease), transform .7s var(--ease); }
    .reveal.on { opacity:1; transform: none; }
    .d1 { transition-delay:.05s; } .d2 { transition-delay:.15s; } .d3 { transition-delay:.25s; }

    @media (max-width: 600px) {
      .suc-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <nav class="nav" id="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">
        <img src="/Logo BlancoEsp.png" alt="Ópticas Jarmar" style="height:44px; width:auto; object-fit:contain;" />
      </a>
      <div class="nav-links" id="navLinks">
        <a href="/">Inicio</a>
        <a href="/chiapas/">Chiapas</a>
        <a href="/tijuana/">Tijuana</a>
        <a href="/blog/">Blog</a>
        <a href="https://wa.me/528711645920" target="_blank" class="nav-cta">Agendar cita</a>
      </div>
      <div class="nav-burger" id="burger" onclick="toggleMenu()">
        <span></span><span></span><span></span>
      </div>
    </div>
  </nav>

  <!-- ═══ HEADER ═══ -->
  <header class="header">
    <div class="hex-bg">
      <div class="hex hex-1"><svg viewBox="0 0 100 115" width="220"><polygon points="50 0 100 28.75 100 86.25 50 115 0 86.25 0 28.75"/></svg></div>
      <div class="hex hex-2"><svg viewBox="0 0 100 115" width="160"><polygon points="50 0 100 28.75 100 86.25 50 115 0 86.25 0 28.75"/></svg></div>
      <div class="hex hex-3"><svg viewBox="0 0 100 115" width="100"><polygon points="50 0 100 28.75 100 86.25 50 115 0 86.25 0 28.75"/></svg></div>
    </div>

    <div style="position:relative; z-index:1;">

      <!-- Foto circular -->
      <div class="avatar-wrap">
        <div class="avatar">
          <img src="/Aaron.jpeg" alt="Opt. Aarón Linares" />
        </div>
      </div>

      <h1 class="header-name">Opt. Aarón Linares</h1>
      <p class="header-sub">Optometría y Contactología Especializada</p>

      <div style="display:flex; flex-direction:column; align-items:center; gap:12px;">
        <a href="/contacto-aaron-linares.vcf" download class="header-phone">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
          Guardar contacto
        </a>
        <a href="https://wa.me/528711645920" target="_blank" class="header-phone" style="background:rgba(37,211,102,0.15); border-color:rgba(37,211,102,0.35); color:#5BDB7E;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.852L0 24l6.336-1.508A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.37l-.36-.214-3.732.888.932-3.641-.235-.374A9.818 9.818 0 1112 21.818z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>

    <svg class="header-wave" viewBox="0 0 1440 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 48L1440 48L1440 16C1200 48 720 0 0 32V48Z" fill="#F7F9FC"/>
    </svg>
  </header>

  <!-- ═══ SUCURSALES ═══ -->
  <section class="sucursales">
    <div class="suc-titulo reveal">
      <div class="tag">Mi ubicación</div>
      <h2>Encuéntrame en<br><em style="font-style:italic; color:#1A5BB5;">esta sucursal</em></h2>
    </div>

    <div class="suc-grid" style="max-width:400px; margin:0 auto;">

      <!-- Tijuana -->
      <div class="suc-card reveal d1">
        <div class="suc-card-header">
          <div class="suc-num">01</div>
          <div class="suc-city">Tijuana · Baja California</div>
          <div class="suc-name">Zona Urbana Río</div>
        </div>
        <div class="suc-card-body">
          <div class="suc-address">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 6-9 13-9 13S3 16 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <p>David Alfaro Siqueiros #2795 local 101<br>Zona Urbana Río, Tijuana, B.C.</p>
          </div>
          <div class="suc-actions">
            <a href="https://maps.app.goo.gl/nyrjM9WuBSQv3qb97" target="_blank" class="btn-maps">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 6-9 13-9 13S3 16 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              Ver en Google Maps
            </a>
            <a href="https://wa.me/526645791970" class="btn-tel" target="_blank"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.852L0 24l6.336-1.508A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.006-1.37l-.36-.214-3.732.888.932-3.641-.235-.374A9.818 9.818 0 1112 21.818z"/></svg>
              Citas: 664 579 1970</a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ CIERRE ═══ -->
  <section style="background: var(--grad-hero); padding: 52px 28px; text-align: center; position: relative; overflow: hidden;">
    <div style="position:relative; z-index:1;">
      <div style="display:inline-flex; align-items:center; gap:16px; flex-wrap:wrap; justify-content:center;">
        <img src="/LogoS blanco.png" alt="Jarmar" style="width:42px; height:42px; object-fit:contain; opacity:0.9;" />
        <p style="font-family: var(--font-display); font-size: clamp(1rem, 3vw, 1.35rem); color: var(--blanco); font-weight: 400; line-height:1.4;">
          Jarmar &bull; <em style="font-style:italic; color: var(--azul-claro);">60 años de cuidar tu salud visual</em><br>y la de tu familia
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="footer">
    <div class="footer-logo">
      <img src="/Logo BlancoEsp.png" alt="Ópticas Jarmar" style="height:36px; width:auto; object-fit:contain;" />
    </div>
  </footer>

  <script>
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('on'); obs.unobserve(e.target); } });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 60));
    nav.classList.add('scrolled');
    function toggleMenu() { document.getElementById('navLinks').classList.toggle('open'); }
    document.querySelectorAll('#navLinks a').forEach(a => a.addEventListener('click', () => document.getElementById('navLinks').classList.remove('open')));
  </script>
</body>
</html>
