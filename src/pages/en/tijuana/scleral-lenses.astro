---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Scleral Lenses in Tijuana | Keratoconus Specialists | Ópticas Jarmar Zona Río"
  description="Specialists in scleral contact lenses for keratoconus, corneal transplant, dry eye and irregular cornea in Tijuana. Over 10 years of experience. Ópticas Jarmar Zona Río."
  alternates={[
    { hreflang: "en", href: "https://jarmar.com/en/tijuana/scleral-lenses/" },
    { hreflang: "es", href: "https://jarmar.com/tijuana/lentes-esclerales/" },
    { hreflang: "x-default", href: "https://jarmar.com/tijuana/lentes-esclerales/" }
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are scleral contact lenses?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Scleral lenses are large-diameter rigid gas-permeable contact lenses that vault completely over the cornea and rest on the sclera (the white of the eye). This creates a fluid reservoir between the lens and the cornea, providing crisp vision and continuous hydration even for severely irregular or damaged corneas."
          }
        },
        {
          "@type": "Question",
          "name": "Who needs scleral lenses?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Scleral lenses are indicated for patients with keratoconus, post-corneal transplant, post-LASIK complications, severe dry eye syndrome, pellucid marginal degeneration, and other conditions that cause corneal irregularity. They are the lens of choice when soft or conventional rigid lenses fail to provide adequate vision or comfort."
          }
        },
        {
          "@type": "Question",
          "name": "How long does a scleral lens fitting take?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The full fitting process at Ópticas Jarmar Tijuana typically involves 2–3 visits. The initial evaluation and trial fitting takes about 90 minutes. After the custom lens is ordered (1–2 weeks), a delivery visit confirms fit and acuity. A follow-up visit is scheduled 2–4 weeks later to fine-tune the fit."
          }
        },
        {
          "@type": "Question",
          "name": "Do you serve patients from San Diego and the United States?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Ópticas Jarmar Zona Río in Tijuana is located less than 30 minutes from the San Ysidro border crossing. We regularly fit patients from San Diego, Los Angeles, and across the US who seek specialized scleral lens care at a fraction of the cost compared to US providers. Our team speaks English fluently."
          }
        },
        {
          "@type": "Question",
          "name": "How long do scleral lenses last?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "With proper care, scleral lenses typically last 1 to 3 years. Their lifespan depends on how well they are cleaned and stored, and whether the patient's corneal prescription remains stable. We provide complete care and maintenance instructions at fitting."
          }
        },
        {
          "@type": "Question",
          "name": "Where can I get scleral lenses fitted in Tijuana?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ópticas Jarmar Zona Río is the leading scleral lens specialty center in Tijuana. Located at David Alfaro Siqueiros #2795 local 101, Zona Río, Tijuana. Opt. Jorge Aranda Tello leads the scleral lens program with over 10 years of exclusive specialty in keratoconus and irregular corneas. Contact: +52 664 579 1970."
          }
        }
      ]
    })}</script>
  </Fragment>

  <style>
    :root { --bg: #071A3E; --surface: #0D2B6B; --accent: #3A8FE0; }

    .hero { background: linear-gradient(135deg, var(--bg) 0%, var(--surface) 100%); color: #fff; padding: 100px 20px 80px; text-align: center; }
    .hero-tag { display: inline-block; background: rgba(58,143,224,0.2); border: 1px solid var(--accent); color: var(--accent); border-radius: 100px; padding: 6px 18px; font-size: 0.85rem; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 24px; }
    .hero h1 { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 700; line-height: 1.2; margin-bottom: 20px; }
    .hero h1 span { color: var(--accent); }
    .hero p { font-size: 1.15rem; opacity: 0.85; max-width: 640px; margin: 0 auto 36px; line-height: 1.7; }
    .btn-cta { display: inline-flex; align-items: center; gap: 8px; background: var(--accent); color: #fff; padding: 14px 32px; border-radius: 100px; font-weight: 700; font-size: 1rem; text-decoration: none; transition: opacity 0.2s, transform 0.2s; }
    .btn-cta:hover { opacity: 0.9; transform: translateY(-2px); }

    .container { max-width: 900px; margin: 0 auto; padding: 0 20px; }
    .section { padding: 72px 20px; }
    .section:nth-child(even) { background: #f7f9fc; }
    .section-title { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 700; color: var(--bg); margin-bottom: 16px; }
    .section-title span { color: var(--accent); }
    .section-sub { color: #4a5568; line-height: 1.7; font-size: 1.05rem; margin-bottom: 36px; }

    .que-son-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
    @media (max-width: 640px) { .que-son-inner { grid-template-columns: 1fr; } }
    .que-son-texto p { color: #4a5568; line-height: 1.75; font-size: 1.05rem; margin-bottom: 16px; }
    .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .stat { background: var(--surface); color: #fff; border-radius: 16px; padding: 20px; text-align: center; }
    .stat strong { display: block; font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--accent); }
    .stat span { font-size: 0.85rem; opacity: 0.85; line-height: 1.4; }

    .condiciones { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 20px; }
    .condicion { background: #fff; border-radius: 18px; border: 1.5px solid rgba(58,143,224,0.25); padding: 28px 24px; }
    .condicion-icon { font-size: 2rem; margin-bottom: 14px; display: block; }
    .condicion h4 { font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; color: var(--bg); margin-bottom: 10px; }
    .condicion p { color: #4a5568; font-size: 0.97rem; line-height: 1.65; }

    .proceso { display: flex; flex-direction: column; gap: 0; position: relative; }
    .proceso::before { content: ''; position: absolute; left: 22px; top: 0; bottom: 0; width: 2px; background: rgba(58,143,224,0.3); }
    .paso { display: flex; gap: 24px; align-items: flex-start; padding-bottom: 36px; position: relative; z-index: 1; }
    .paso:last-child { padding-bottom: 0; }
    .paso-num { background: var(--accent); color: #fff; border-radius: 50%; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.1rem; flex-shrink: 0; }
    .paso h4 { font-family: var(--font-display); font-weight: 700; color: var(--bg); margin-bottom: 6px; font-size: 1.05rem; }
    .paso p { color: #4a5568; font-size: 0.97rem; line-height: 1.65; }

    .testimonios { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
    .testimonio { background: var(--surface); color: #fff; border-radius: 18px; padding: 28px 24px; }
    .testimonio-stars { color: #fbbf24; font-size: 1.2rem; margin-bottom: 14px; letter-spacing: 2px; }
    .testimonio p { font-size: 0.97rem; line-height: 1.7; opacity: 0.9; margin-bottom: 16px; font-style: italic; }
    .testimonio-autor { font-weight: 700; font-size: 0.9rem; color: var(--accent); }

    /* FAQ Accordion */
    .faq-list { display: flex; flex-direction: column; gap: 12px; }
    .faq-item { background: #fff; border: 1.5px solid rgba(58,143,224,0.2); border-radius: 16px; overflow: hidden; }
    .faq-question { width: 100%; background: none; border: none; padding: 22px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; text-align: left; font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; color: var(--bg); }
    .faq-question:hover { background: rgba(58,143,224,0.04); }
    .faq-icon { flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%; background: rgba(58,143,224,0.12); color: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; font-weight: 700; transition: transform 0.25s; }
    .faq-item.open .faq-icon { transform: rotate(45deg); }
    .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease; }
    .faq-item.open .faq-answer { max-height: 300px; }
    .faq-answer p { padding: 0 24px 22px; color: #4a5568; font-size: 1rem; line-height: 1.75; margin: 0; }

    /* GEO block */
    .geo-block { background: linear-gradient(135deg, var(--bg) 0%, var(--surface) 100%); border-radius: 24px; color: #fff; padding: 44px 40px; }
    @media (max-width: 600px) { .geo-block { padding: 32px 24px; } }
    .geo-block h2 { font-family: var(--font-display); font-size: clamp(1.3rem, 3vw, 1.9rem); font-weight: 700; margin-bottom: 20px; }
    .geo-block p { font-size: 1.05rem; opacity: 0.9; line-height: 1.8; margin-bottom: 16px; }
    .geo-block p:last-of-type { margin-bottom: 28px; }
    .geo-data { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 32px; }
    .geo-chip { background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.25); border-radius: 100px; padding: 7px 18px; font-size: 0.9rem; font-weight: 600; }

    .cta-section { background: linear-gradient(135deg, var(--bg) 0%, var(--surface) 100%); color: #fff; text-align: center; padding: 80px 20px; }
    .cta-section h2 { font-family: var(--font-display); font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 700; margin-bottom: 16px; }
    .cta-section p { font-size: 1.1rem; opacity: 0.85; margin-bottom: 36px; max-width: 560px; margin-left: auto; margin-right: auto; }

    .back-link { display: block; text-align: center; padding: 28px; color: var(--accent); text-decoration: none; font-size: 0.95rem; font-weight: 600; }
    .back-link:hover { text-decoration: underline; }
  </style>

