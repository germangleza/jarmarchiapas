  <style>
    /* ===================== VARIABLES ===================== */
    :root {
      --azul-oscuro: #0D2B6B;
      --azul-medio: #1A5BB5;
      --azul-claro: #3A8FE0;
      --blanco: #FFFFFF;
      --blanco-hueso: #F7F9FC;
      --gris-suave: #E8EFF8;
      --gris-texto: #4A5568;
      --gris-claro: #718096;
      --sombra: rgba(13,43,107,0.12);
      --sombra-fuerte: rgba(13,43,107,0.25);
      --gradiente-hero: linear-gradient(135deg, #0D2B6B 0%, #1A5BB5 60%, #3A8FE0 100%);
      --gradiente-suave: linear-gradient(180deg, #F7F9FC 0%, #E8EFF8 100%);
      --font-display: 'Playfair Display', Georgia, serif;
      --font-body: 'DM Sans', sans-serif;
      --radius: 16px;
      --radius-sm: 8px;
      --transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
    }

    /* ===================== RESET & BASE ===================== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      font-family: var(--font-body);
      color: var(--azul-oscuro);
      background: var(--blanco);
      overflow-x: hidden;
      line-height: 1.6;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }

    /* ===================== UTILIDADES ===================== */
    .container { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
    .section-tag {
      display: inline-block;
      font-family: var(--font-body);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--azul-medio);
      background: rgba(26,91,181,0.1);
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 16px;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 700;
      line-height: 1.2;
      color: var(--azul-oscuro);
    }
    .section-title span { color: var(--azul-medio); }
    .section-subtitle {
      font-size: 1.05rem;
      color: var(--gris-texto);
      max-width: 600px;
      line-height: 1.7;
    }

    /* ===================== REVEAL ANIMATIONS ===================== */
    .reveal {
      opacity: 0;
      transform: translateY(36px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-left { opacity: 0; transform: translateX(-36px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal-left.visible { opacity: 1; transform: translateX(0); }
    .reveal-right { opacity: 0; transform: translateX(36px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal-right.visible { opacity: 1; transform: translateX(0); }
    .delay-1 { transition-delay: 0.1s; }
    .delay-2 { transition-delay: 0.2s; }
    .delay-3 { transition-delay: 0.3s; }
    .delay-4 { transition-delay: 0.4s; }

    /* Pilar stagger */
    .pilares .pilar.delay-1 { transition-delay: 0s; }
    .pilares .pilar.delay-2 { transition-delay: 0.45s; }
    .pilares .pilar.delay-3 { transition-delay: 0.9s; }

    /* Sucursal: borde animado giratorio */
    @property --angle {
      syntax: '<angle>';
      initial-value: 0deg;
      inherits: false;
    }
    @keyframes rotate-border { to { --angle: 360deg; } }
    .sucursal-wrap {
      border-radius: 30px;
      background: conic-gradient(from var(--angle), transparent 72%, #3A8FE0 82%, #7EC8F5 88%, #3A8FE0 94%, transparent 100%);
      padding: 3px;
      animation: rotate-border 3s linear infinite;
      max-width: 700px;
      margin: 0 auto;
    }
    .sucursal-wrap .sucursal-card {
      border: none !important;
      border-radius: 26px;
      max-width: none;
      margin: 0;
    }

    /* ===================== NAVBAR ===================== */
    .navbar.scrolled { background: rgba(13,43,107,0.97); }
    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      padding: 16px 0;
      transition: var(--transition);
    }
    .navbar.scrolled {
      background: rgba(13,43,107,0.97);
      backdrop-filter: blur(12px);
      box-shadow: 0 4px 24px var(--sombra-fuerte);
      padding: 10px 0;
    }
    .navbar-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo { display: flex; align-items: center; gap: 10px; }
    .logo-mark {
      width: 48px; height: 48px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
    }
    .logo-mark img { width: 100%; height: 100%; object-fit: contain; }
    .logo-text { color: var(--blanco); }
    .logo-text strong { display: block; font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; line-height: 1; }
    .logo-text span { font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.8; }
    .nav-links { display: flex; align-items: center; gap: 28px; }
    .nav-links a { color: rgba(255,255,255,0.85); font-size: 0.9rem; font-weight: 500; transition: var(--transition); }
    .nav-links a:hover { color: var(--blanco); }
    .nav-cta {
      background: var(--blanco);
      color: var(--azul-oscuro) !important;
      padding: 10px 22px;
      border-radius: 100px;
      font-weight: 600 !important;
      font-size: 0.88rem !important;
      transition: var(--transition) !important;
      box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    }
    .nav-cta:hover { background: var(--blanco-hueso); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important; }
    .nav-burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
    .nav-burger span { width: 24px; height: 2px; background: var(--blanco); border-radius: 2px; transition: var(--transition); }

    /* ===================== HERO ===================== */
    .hero {
      position: relative;
      min-height: 100vh;
      background: url('/IMG-1929.JPG') center/cover no-repeat;
      display: flex; align-items: center;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(120deg, rgba(7,26,62,0.90) 0%, rgba(13,43,107,0.75) 55%, rgba(26,91,181,0.50) 100%);
    }
    .hero-orb {
      display: none;
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.25;
      animation: float 8s ease-in-out infinite;
    }
    .hero-orb-1 { width: 500px; height: 500px; background: #3A8FE0; top: -100px; right: -80px; }
    .hero-orb-2 { width: 350px; height: 350px; background: #0D2B6B; bottom: -80px; left: -60px; animation-delay: -4s; }
    @keyframes float { 0%,100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-20px) scale(1.04); } }

    .hero-inner {
      position: relative; z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 120px 0 80px;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      backdrop-filter: blur(8px);
      padding: 8px 16px;
      border-radius: 100px;
      font-size: 0.8rem;
      color: rgba(255,255,255,0.9);
      margin-bottom: 24px;
      font-weight: 500;
    }
    .hero-badge-dot { width: 8px; height: 8px; background: #4ADE80; border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(2.8rem, 6vw, 4.8rem);
      font-weight: 900;
      color: var(--blanco);
      line-height: 1.05;
      margin-bottom: 24px;
    }
    .hero-headline em { font-style: normal; color: #7EC8F5; }
    .hero-sub {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.82);
      line-height: 1.75;
      margin-bottom: 36px;
      max-width: 520px;
    }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--blanco);
      color: var(--azul-oscuro);
      padding: 16px 30px;
      border-radius: 100px;
      font-weight: 700; font-size: 0.95rem;
      transition: var(--transition);
      box-shadow: 0 4px 24px rgba(0,0,0,0.2);
    }
    .btn-primary:hover { background: #EEF5FF; transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
    .btn-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent;
      color: var(--blanco);
      padding: 16px 28px;
      border-radius: 100px;
      font-weight: 600; font-size: 0.95rem;
      border: 2px solid rgba(255,255,255,0.35);
      transition: var(--transition);
    }
    .btn-secondary:hover { border-color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.08); }
    .hero-review {
      display: flex; align-items: center; gap: 12px; margin-top: 24px;
      justify-content: center;
    }
    .review-avatars { display: flex; }
    .review-avatars img {
      width: 36px; height: 36px; border-radius: 50%;
      border: 2px solid #fff; object-fit: cover;
      margin-left: -10px;
    }
    .review-avatars img:first-child { margin-left: 0; }
    .review-text { display: flex; flex-direction: column; gap: 2px; }
    .review-stars { color: #F6AD55; font-size: 0.9rem; letter-spacing: 1px; }
    .review-label { color: rgba(255,255,255,0.75); font-size: 0.8rem; font-weight: 500; }
    .hero-stats {
      display: flex; gap: 32px;
      margin-top: 48px;
      padding-top: 36px;
      border-top: 1px solid rgba(255,255,255,0.15);
    }
    .hero-stat strong { display: block; font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--blanco); line-height: 1; }
    .hero-stat span { font-size: 0.78rem; color: rgba(255,255,255,0.65); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 4px; display: block; }
    .hero-img { display: none; }
    .hero-img-frame {
      position: relative; width: 100%; max-width: 500px;
      aspect-ratio: 4/5; border-radius: 28px; overflow: hidden;
      box-shadow: 0 32px 80px rgba(0,0,0,0.35);
    }
    .hero-img-frame img { width: 100%; height: 100%; object-fit: cover; }
    .hero-img-placeholder {
      width: 100%; height: 100%;
      background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.04) 100%);
      border: 2px dashed rgba(255,255,255,0.25);
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px;
      color: rgba(255,255,255,0.5); font-size: 0.85rem; text-align: center; padding: 20px;
    }
    .hero-card {
      position: absolute;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(12px);
      border-radius: var(--radius);
      padding: 16px 20px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    }
    .hero-card-1 { bottom: 32px; left: -24px; }
    .hero-card-2 { top: 32px; right: -24px; }
    .hero-card p { font-size: 0.78rem; color: var(--gris-texto); margin-top: 2px; }
    .hero-card strong { font-size: 0.9rem; color: var(--azul-oscuro); }
    .stars { color: #F59E0B; font-size: 0.75rem; letter-spacing: 1px; }

    /* ===================== CONFIANZA BAR ===================== */
    .trust-bar { background: var(--azul-oscuro); padding: 28px 0; }
    .trust-bar-inner {
      display: flex; align-items: center; justify-content: center;
      flex-wrap: wrap;
    }
    .trust-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 6px;
      padding: 12px 32px;
      border-right: 1px solid rgba(255,255,255,0.12);
      color: var(--blanco);
    }
    .trust-item:last-child { border-right: none; }
    .trust-icon { font-size: 1.4rem; }
    .trust-item strong { display: block; font-size: 1.1rem; font-family: var(--font-display); }
    .trust-item span { font-size: 0.75rem; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 0.1em; }

    /* ===================== PROBLEMA ===================== */
    .problema {
      position: relative;
      padding: 100px 0;
      background: url('/ATENCION.jpg') center/cover no-repeat;
    }
    .problema::before {
      content: '';
      position: absolute; inset: 0;
      background: rgba(7, 26, 62, 0.70);
    }
    .problema .container { position: relative; z-index: 1; }
    .problema .section-tag { color: rgba(255,255,255,0.75); }
    .problema .section-title { color: #fff; }
    .problema .section-title span { color: #7EC8F5; }
    .problema .section-subtitle { color: rgba(255,255,255,0.72); }
    .problema-inner {
      display: flex; flex-direction: column; align-items: center; text-align: center;
    }
    .pain-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; margin: 32px 0 40px; width: 100%; }
    .pain-card {
      background: rgba(255,255,255,0.12); border-radius: 14px; padding: 20px 22px;
      border: 1.5px solid rgba(255,255,255,0.2);
      font-size: 0.95rem; font-weight: 500; color: #fff;
      backdrop-filter: blur(8px);
    }
    @media (max-width: 640px) { .pain-grid { grid-template-columns: 1fr; } }

    /* ===================== SOLUCIÓN ===================== */
    .solucion { padding: 100px 0; background: var(--gradiente-suave); }
    .solucion-header { text-align: center; margin-bottom: 60px; }
    .solucion-header .section-subtitle { margin: 16px auto 0; }
    .pilares { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .pilar {
      background: var(--blanco);
      border-radius: 32px;
      padding: 28px 28px;
      box-shadow: 0 4px 24px var(--sombra);
      position: relative;
      overflow: hidden;
      transition: var(--transition);
      border: 1px solid rgba(26,91,181,0.08);
    }
    .pilar:hover { transform: translateY(-6px); box-shadow: 0 16px 48px var(--sombra-fuerte); }
    .pilar::before { display: none; }
    .pilar-num {
      font-family: var(--font-display); font-size: 4rem; font-weight: 900;
      color: var(--azul-medio); opacity: 0.08;
      position: absolute; top: 16px; right: 20px; line-height: 1;
    }
    .pilar-icon {
      width: 56px; height: 56px;
      background: linear-gradient(135deg, var(--azul-oscuro), var(--azul-medio));
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.5rem; margin-bottom: 20px;
      box-shadow: 0 4px 16px rgba(26,91,181,0.3);
    }
    .pilar h3 { font-family: var(--font-display); font-size: 1.35rem; font-weight: 700; margin-bottom: 12px; color: var(--azul-oscuro); }
    .pilar p { font-size: 0.92rem; color: var(--gris-texto); line-height: 1.7; }
    .pilar-list { margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }
    .pilar-list li { font-size: 0.92rem; color: var(--gris-texto); display: flex; align-items: center; gap: 8px; list-style: none; }
    .pilar-list li::before { content: '✓'; color: var(--azul-medio); font-weight: 700; font-size: 0.8rem; flex-shrink: 0; }

    /* ===================== DIFERENCIADORES ===================== */
    .diferenciadores {
      padding: 100px 0;
      background: var(--gradiente-hero);
      position: relative;
      overflow: hidden;
    }
    .diferenciadores::before { display: none; }
    .diferenciadores .container { position: relative; z-index: 2; }
    .diferenciadores .section-tag { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }
    .diferenciadores .section-title { color: var(--blanco); }
    .dif-header { margin-bottom: 60px; }
    .dif-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .dif-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 24px; padding: 36px 28px;
      backdrop-filter: blur(8px);
      transition: var(--transition);
      position: relative; overflow: hidden;
    }
    .dif-card:hover { background: rgba(255,255,255,0.1); transform: translateY(-4px); border-color: rgba(255,255,255,0.2); }
    .dif-card::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0;
      height: 3px; background: linear-gradient(90deg, var(--azul-claro), transparent);
      opacity: 0; transition: var(--transition);
    }
    .dif-card:hover::after { opacity: 1; }
    .dif-icon { font-size: 2.4rem; margin-bottom: 20px; display: block; }
    .dif-card h3 { font-family: var(--font-display); font-size: 1.25rem; color: var(--blanco); margin-bottom: 12px; }
    .dif-card p { font-size: 0.9rem; color: rgba(255,255,255,1); line-height: 1.7; }

    /* ===================== ESTRELLA — ESCLERALES ===================== */
    .estrella {
      padding: 100px 0; background: var(--blanco);
    }
    .estrella-inner {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: center;
    }
    .estrella-img-wrap { position: relative; }
    .estrella-img-frame {
      border-radius: 24px; overflow: hidden;
      aspect-ratio: 1/1; box-shadow: 0 20px 60px var(--sombra);
    }
    .estrella-img-frame img { width:100%; height:100%; object-fit:cover; }
    .estrella-badge-float {
      position: absolute; top: 24px; left: 24px;
      background: var(--azul-oscuro); color: var(--blanco);
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      padding: 8px 16px; border-radius: 100px;
      box-shadow: 0 4px 16px var(--sombra-fuerte);
    }
    .estrella-years {
      position: absolute; bottom: 24px; right: -20px;
      background: var(--gradiente-hero); color: var(--blanco);
      border-radius: 20px; padding: 20px 24px; text-align: center;
      box-shadow: 0 8px 32px var(--sombra-fuerte);
    }
    .estrella-years strong { display: block; font-family: var(--font-display); font-size: 2.4rem; font-weight: 900; line-height: 1; }
    .estrella-years span { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.12em; opacity: 0.8; }
    .estrella-list { margin-top: 24px; display: flex; flex-direction: column; gap: 14px; margin-bottom: 36px; }
    .estrella-item {
      display: flex; align-items: flex-start; gap: 14px;
      background: var(--blanco-hueso);
      border-radius: var(--radius-sm); padding: 14px 18px;
      border-left: 3px solid var(--azul-medio);
      transition: var(--transition);
    }
    .estrella-item:hover { background: var(--gris-suave); transform: translateX(4px); }
    .estrella-item-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 1px; }
    .estrella-item p { font-size: 0.9rem; color: var(--gris-texto); line-height: 1.6; }
    .btn-azul {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--azul-oscuro); color: var(--blanco);
      padding: 16px 30px; border-radius: 100px;
      font-weight: 700; font-size: 0.92rem;
      transition: var(--transition);
      box-shadow: 0 4px 20px var(--sombra-fuerte);
    }
    .btn-azul:hover { background: var(--azul-medio); transform: translateY(-2px); box-shadow: 0 8px 28px var(--sombra-fuerte); }

    /* ===================== SERVICIOS ===================== */
    .servicios { padding: 100px 0; background: #EBF4FF; }
    .servicios-header { text-align: center; margin-bottom: 60px; }
    .servicios-header .section-subtitle { margin: 16px auto 0; }
    .servicios-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .servicio-card {
      display: block;
      text-decoration: none;
      color: inherit;
      cursor: pointer;
      background: var(--blanco);
      border-radius: 20px;
      padding: 32px 24px;
      text-align: center;
      transition: var(--transition);
      border: 1.5px solid rgba(26,91,181,0.25);
    }
    .servicio-card:hover { box-shadow: 0 12px 40px var(--sombra); transform: translateY(-4px); border-color: rgba(26,91,181,0.5); }
    .servicio-icon { font-size: 2.2rem; margin-bottom: 14px; display: block; }
    .servicio-card h4 { font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; color: var(--azul-oscuro); margin-bottom: 8px; }
    .servicio-card p { font-size: 1.05rem; color: var(--gris-texto); line-height: 1.7; }
    .servicio-more { display: block; margin-top: 14px; font-size: 0.82rem; font-weight: 700; color: var(--azul-medio); transition: var(--transition); }
    .servicio-card:hover .servicio-more { color: var(--azul-oscuro); }
    .servicio-cta { text-align: center; margin-top: 48px; }
    .btn-outline {
      display: inline-flex; align-items: center; gap: 8px;
      border: 2px solid var(--azul-medio); color: var(--azul-medio);
      padding: 14px 28px; border-radius: 100px;
      font-weight: 600; font-size: 0.92rem;
      transition: var(--transition);
    }
    .btn-outline:hover { background: var(--azul-medio); color: var(--blanco); }

    /* ===================== SUCURSAL ===================== */
    .sucursal { padding: 100px 0; background: var(--blanco); }
    .sucursal-header { text-align: center; margin-bottom: 60px; }
    .sucursal-header .section-subtitle { margin: 16px auto 0; }
    .sucursal-card {
      max-width: 700px; margin: 0 auto;
      background: var(--azul-oscuro);
      border-radius: 28px; overflow: hidden;
      box-shadow: 0 20px 60px var(--sombra-fuerte);
      position: relative;
    }
    .sucursal-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0;
      height: 4px; background: var(--gradiente-hero);
    }
    .sucursal-body { padding: 48px; }
    .sucursal-name {
      font-family: var(--font-display); font-size: 2rem; font-weight: 700;
      color: var(--blanco); margin-bottom: 32px; line-height: 1.2;
    }
    .sucursal-name span { display: block; font-size: 1rem; font-weight: 400; color: rgba(255,255,255,0.5); font-family: var(--font-body); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.12em; }
    .sucursal-info { display: flex; flex-direction: column; gap: 16px; margin-bottom: 36px; }
    .sucursal-dato {
      display: flex; align-items: flex-start; gap: 14px;
      background: rgba(255,255,255,0.06);
      border-radius: var(--radius-sm); padding: 14px 18px;
    }
    .sucursal-dato-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }
    .sucursal-dato div strong { display: block; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); margin-bottom: 3px; }
    .sucursal-dato div p { font-size: 0.9rem; color: rgba(255,255,255,0.85); line-height: 1.5; }
    .sucursal-actions { display: flex; gap: 14px; flex-wrap: wrap; }
    .btn-maps {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
      color: var(--blanco); padding: 14px 24px;
      border-radius: 100px; font-weight: 600; font-size: 0.88rem;
      transition: var(--transition);
    }
    .btn-maps:hover { background: rgba(255,255,255,0.18); }

    /* ===================== PRUEBA SOCIAL ===================== */
    .prueba-social { padding: 100px 0; background: var(--gradiente-suave); }
    .ps-header { text-align: center; margin-bottom: 60px; }
    .ps-header .section-subtitle { margin: 16px auto 0; }
    .stats-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 64px; }
    .stat-card {
      background: var(--blanco); border-radius: 20px; padding: 28px 20px;
      text-align: center; box-shadow: 0 4px 20px var(--sombra);
      border: 1px solid rgba(26,91,181,0.06); transition: var(--transition);
    }
    .stat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px var(--sombra-fuerte); }
    .stat-num { font-family: var(--font-display); font-size: 2.4rem; font-weight: 900; color: var(--azul-medio); line-height: 1; }
    .stat-label { font-size: 0.78rem; color: var(--gris-claro); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 6px; }
    /* ── RESEÑAS ── */
    .rating-head { margin-bottom: clamp(28px, 5vw, 44px); }
    .rating-row { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
    .rating-num { font-size: 1.2rem; font-weight: 700; color: var(--azul-oscuro); font-variant-numeric: tabular-nums; }
    .rating-stars { color: #F6AD55; letter-spacing: .08em; font-size: .9rem; }
    .rating-src { display: inline-flex; align-items: center; gap: 5px; font-size: .75rem; color: var(--gris-claro); text-transform: uppercase; letter-spacing: .08em; }
    .rating-head h2 { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2.1rem); color: var(--azul-oscuro); margin: 0 0 8px; line-height: 1.2; }
    .rating-sub { color: var(--gris-claro); font-size: 0.95rem; margin: 0; }

    .testimonios {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
    }
    @media (max-width: 600px) {
      .testimonios {
        grid-auto-flow: column; grid-auto-columns: 82%;
        grid-template-columns: none;
        overflow-x: auto; scroll-snap-type: x mandatory;
        scroll-padding-inline: 20px;
        margin-inline: -20px; padding-inline: 20px; padding-bottom: 8px;
        scrollbar-width: none; overscroll-behavior-x: contain;
      }
      .testimonios::-webkit-scrollbar { display: none; }
      .testimonio { scroll-snap-align: start; }
    }
    .testimonio {
      display: flex; flex-direction: column; gap: 12px;
      background: var(--blanco);
      border: 1px solid rgba(26,91,181,0.12); border-radius: 6px;
      padding: clamp(20px, 3vw, 28px);
      transition: border-color 220ms ease, transform 220ms ease;
    }
    .testimonio::before { display: none; }
    @media (hover: hover) {
      .testimonio:hover { border-color: var(--azul-oscuro); transform: translateY(-2px); box-shadow: none; }
    }
    .testimonio-hook {
      font-size: clamp(1.05rem, 2vw, 1.3rem);
      font-weight: 700; line-height: 1.3; letter-spacing: -.01em;
      color: var(--azul-oscuro); margin: 0;
    }
    .testimonio-hook::before { content: "\201C"; color: var(--azul-claro); margin-right: 2px; }
    .testimonio p { font-size: .9rem; color: var(--gris-texto); line-height: 1.65; margin: 0; flex: 1; padding-top: 0; position: static; }
    .testimonio-autor {
      display: grid; grid-template-columns: auto 1fr;
      align-items: center; gap: 4px 10px;
      padding-top: 14px; border-top: 1px solid rgba(26,91,181,0.1); margin-top: auto;
    }
    .autor-avatar {
      grid-row: span 2;
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--azul-oscuro), var(--azul-claro));
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-size: 0.75rem; font-weight: 700;
      color: var(--blanco); flex-shrink: 0;
    }
    .autor-info strong { font-size: 0.85rem; color: var(--azul-oscuro); display: block; }
    .autor-fuente { display: inline-flex; align-items: center; gap: 4px; font-size: .72rem; color: var(--gris-claro); }
    .ver-resenas {
      display: inline-flex; align-items: center; gap: 8px; margin-top: 24px;
      font-size: .9rem; font-weight: 600; color: var(--azul-oscuro);
      text-decoration: none;
      border-bottom: 1px solid rgba(26,91,181,0.2); padding-bottom: 3px;
      transition: border-color 200ms ease;
    }
    .ver-resenas:hover { border-color: var(--azul-medio); }
    .ver-resenas .arrow { transition: transform 200ms ease; display: inline-block; }
    .ver-resenas:hover .arrow { transform: translateX(4px); }

    /* ===================== FAQ ===================== */
    .faq { padding: 100px 0; background: var(--blanco); }
    .faq-inner { display: grid; grid-template-columns: 1fr 1.6fr; gap: 80px; align-items: start; }
    .faq-left { position: sticky; top: 100px; }
    .faq-left .section-subtitle { margin-top: 16px; }
    .faq-cta-box {
      margin-top: 36px; background: var(--gradiente-hero);
      border-radius: 20px; padding: 28px 24px; color: var(--blanco);
    }
    .faq-cta-box p { font-size: 0.9rem; opacity: 0.85; margin-bottom: 16px; line-height: 1.6; }
    .btn-white {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--blanco); color: var(--azul-oscuro);
      padding: 12px 22px; border-radius: 100px;
      font-weight: 700; font-size: 0.88rem; transition: var(--transition);
    }
    .btn-white:hover { background: #EEF5FF; transform: translateY(-1px); }
    .faq-list { display: flex; flex-direction: column; gap: 16px; }
    .faq-item { border: 1px solid var(--gris-suave); border-radius: var(--radius); overflow: hidden; transition: var(--transition); }
    .faq-item.open { border-color: rgba(26,91,181,0.2); box-shadow: 0 4px 20px var(--sombra); }
    .faq-q {
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
      padding: 22px 24px; cursor: pointer; user-select: none;
      background: var(--blanco); transition: var(--transition);
    }
    .faq-q:hover { background: var(--blanco-hueso); }
    .faq-q h4 { font-size: 0.95rem; font-weight: 600; color: var(--azul-oscuro); line-height: 1.4; }
    .faq-arrow {
      width: 28px; height: 28px; background: var(--gris-suave);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; transition: var(--transition);
    }
    .faq-item.open .faq-arrow { background: var(--azul-medio); transform: rotate(180deg); }
    .faq-item.open .faq-arrow svg path { stroke: white; }
    .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; }
    .faq-item.open .faq-a { max-height: 300px; }
    .faq-a-inner { padding: 0 24px 24px; }
    .faq-a-inner p { font-size: 0.9rem; color: var(--gris-texto); line-height: 1.75; }

    /* ===================== CTA FINAL ===================== */
    .cta-final {
      padding: 100px 0;
      background: var(--gradiente-hero);
      position: relative; overflow: hidden; text-align: center;
    }
    .cta-final::before { display: none; }
    .cta-orb { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.2; }
    .cta-orb-1 { width: 400px; height: 400px; background: #7EC8F5; top: -100px; left: -80px; }
    .cta-orb-2 { width: 300px; height: 300px; background: #0D2B6B; bottom: -80px; right: -60px; }
    .cta-final .container { position: relative; z-index: 2; }
    .cta-final .section-tag { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.85); }
    .cta-title {
      font-family: var(--font-display); font-size: clamp(2rem, 4.5vw, 3.2rem);
      font-weight: 900; color: var(--blanco); margin: 16px 0; line-height: 1.15;
    }
    .cta-sub { font-size: 1.05rem; color: rgba(255,255,255,0.78); max-width: 560px; margin: 0 auto 40px; line-height: 1.7; }
    .cta-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .btn-whatsapp {
      display: inline-flex; align-items: center; gap: 12px;
      background: #25D366; color: var(--blanco);
      padding: 18px 36px; border-radius: 100px;
      font-weight: 700; font-size: 1rem;
      transition: var(--transition);
      box-shadow: 0 4px 24px rgba(37,211,102,0.4);
    }
    .btn-whatsapp:hover { background: #1db954; transform: translateY(-2px); box-shadow: 0 8px 32px rgba(37,211,102,0.5); }
    .cta-nota { margin-top: 20px; font-size: 0.8rem; color: rgba(255,255,255,0.5); }

    /* ===================== FOOTER ===================== */
    footer { background: #07193E; padding: 60px 0 28px; }
    .footer-inner {
      display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 48px;
      padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 28px;
    }
    .footer-brand .logo { margin-bottom: 16px; }
    .footer-brand p { font-size: 0.85rem; color: rgba(255,255,255,0.5); line-height: 1.7; }
    .footer-col h5 { color: var(--blanco); font-size: 0.82rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 16px; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-col ul li a { font-size: 0.85rem; color: rgba(255,255,255,0.5); transition: var(--transition); }
    .footer-col ul li a:hover { color: var(--blanco); }
    .footer-bottom { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .footer-bottom p { font-size: 0.78rem; color: rgba(255,255,255,0.3); }
    .footer-social { display: flex; gap: 10px; }
    .social-btn {
      width: 36px; height: 36px; background: rgba(255,255,255,0.08);
      border-radius: 8px; display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem; color: rgba(255,255,255,0.6); transition: var(--transition);
    }
    .social-btn:hover { background: var(--azul-medio); color: var(--blanco); }

    /* ===================== WHATSAPP FLOTANTE ===================== */
    .wa-float { position: fixed; bottom: 28px; right: 28px; z-index: 999; display: flex; align-items: center; gap: 12px; }
    .wa-label {
      background: var(--azul-oscuro); color: var(--blanco);
      font-size: 0.8rem; font-weight: 600; padding: 10px 16px;
      border-radius: 100px; white-space: nowrap;
      box-shadow: 0 4px 16px var(--sombra-fuerte);
      opacity: 0; transform: translateX(10px); transition: var(--transition); pointer-events: none;
    }
    .wa-float:hover .wa-label { opacity: 1; transform: translateX(0); }
    .wa-btn {
      width: 62px; height: 62px; background: #25D366; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 6px 24px rgba(37,211,102,0.45); transition: var(--transition);
      animation: wa-pulse 3s ease-in-out infinite; flex-shrink: 0;
    }
    .wa-btn:hover { transform: scale(1.08); box-shadow: 0 10px 32px rgba(37,211,102,0.6); }
    @keyframes wa-pulse {
