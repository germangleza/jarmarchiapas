---
// Landing de campaña: Examen de la Vista Tijuana
// Ruta: /tijuana/examen
// Tráfico: Google Ads — sin menú, sin links de fuga
---
<!DOCTYPE html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/LogoXS color.png" />
  <title>Examen de la Vista en Tijuana | Ópticas Jarmar · Zona Río</title>
  <meta name="description" content="Examen de la vista completo en Tijuana con equipo de precisión. 60 años de experiencia. Agenda hoy tu cita en Zona Río." />
  <!-- No index: landing de pago, no queremos tráfico orgánico duplicado -->
  <meta name="robots" content="noindex, nofollow" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Google Ads — pega tu ID cuando tengas la etiqueta -->
  <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=AW-XXXXXXXXXX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-XXXXXXXXXX');
  </script> -->

  <style>
    :root {
      --azul:      #071A3E;
      --azul-med:  #0D2B6B;
      --azul-vivo: #1A5BB5;
      --acento:    #3A8FE0;
      --blanco:    #FFFFFF;
      --crema:     #F4F8FF;
      --muted:     #8899AA;
      --verde-wa:  #25D366;
      --grad:      linear-gradient(135deg, #071A3E 0%, #0D2B6B 55%, #1A5BB5 100%);
      --grad-btn:  linear-gradient(135deg, #1A5BB5 0%, #3A8FE0 100%);
      --trans:     all 0.3s cubic-bezier(0.4,0,0.2,1);
      --radius:    14px;
      --shadow:    0 4px 24px rgba(7,26,62,0.18);
      --font-d:    'Playfair Display', Georgia, serif;
      --font-b:    'DM Sans', system-ui, sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } * { transition: none !important; animation: none !important; } }
    body { font-family: var(--font-b); color: var(--azul); background: var(--crema); -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }
    :focus-visible { outline: 2px solid var(--acento); outline-offset: 3px; }

    /* ── CONTAINER ── */
    .wrap { max-width: 900px; margin: 0 auto; padding: 0 20px; }
    .wrap-sm { max-width: 600px; margin: 0 auto; padding: 0 20px; }

    /* ── HEADER MÍNIMO ── */
    .lp-header {
      background: var(--azul);
      padding: 16px 0;
      position: sticky; top: 0; z-index: 100;
      box-shadow: 0 2px 16px rgba(7,26,62,0.3);
    }
    .lp-header .wrap {
      display: flex; align-items: center; justify-content: space-between;
    }
    .lp-header img { height: 40px; width: auto; }
    .lp-header-right { display: flex; align-items: center; gap: 16px; }
    .lp-tel {
      color: rgba(255,255,255,0.75); font-size: 0.88rem; font-weight: 500;
      display: flex; align-items: center; gap: 6px;
    }
    .lp-tel:hover { color: #fff; }

    /* ── BOTONES ── */
    .btn-primary {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: var(--grad-btn); color: #fff;
      padding: 14px 28px; border-radius: 100px;
      font-family: var(--font-b); font-size: 1rem; font-weight: 700;
      border: none; cursor: pointer; transition: var(--trans);
      box-shadow: 0 4px 20px rgba(58,143,224,0.35);
      text-decoration: none;
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(58,143,224,0.45); }
    .btn-primary.sm { padding: 11px 22px; font-size: 0.9rem; }

    .btn-wa {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: var(--verde-wa); color: #fff;
      padding: 14px 28px; border-radius: 100px;
      font-family: var(--font-b); font-size: 1rem; font-weight: 700;
      border: none; cursor: pointer; transition: var(--trans);
      box-shadow: 0 4px 20px rgba(37,211,102,0.3);
      text-decoration: none;
    }
    .btn-wa:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(37,211,102,0.4); }
    .btn-wa.sm { padding: 11px 22px; font-size: 0.9rem; }
    .btn-wa.outline {
      background: transparent; border: 2px solid var(--verde-wa); color: var(--verde-wa);
      box-shadow: none;
    }
    .btn-wa.outline:hover { background: rgba(37,211,102,0.08); }

    .btn-ghost {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: transparent; color: #fff;
      padding: 13px 26px; border-radius: 100px; border: 2px solid rgba(255,255,255,0.4);
      font-family: var(--font-b); font-size: 1rem; font-weight: 600;
      cursor: pointer; transition: var(--trans); text-decoration: none;
    }
    .btn-ghost:hover { border-color: #fff; background: rgba(255,255,255,0.08); }

    .btn-group { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }

    /* ── HERO ── */
    .hero {
      background: var(--grad);
      padding: 56px 0 64px;
    }
    .hero .wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
    .hero-eyebrow {
      display: inline-block;
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--acento);
      background: rgba(58,143,224,0.15); border: 1px solid rgba(58,143,224,0.3);
      padding: 5px 14px; border-radius: 100px; margin-bottom: 20px;
    }
    .hero h1 {
      font-family: var(--font-d);
      font-size: clamp(2rem, 4vw, 3rem);
      color: #fff; line-height: 1.15; margin-bottom: 14px;
    }
    .hero-sub { color: rgba(255,255,255,0.75); font-size: 1.05rem; margin-bottom: 20px; }
    .hero-chip {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(37,211,102,0.15); border: 1px solid rgba(37,211,102,0.35);
      color: #5BDB7E; font-size: 0.82rem; font-weight: 600;
      padding: 6px 14px; border-radius: 100px; margin-bottom: 20px;
    }
    .trust-row {
      display: flex; flex-wrap: wrap; gap: 16px; align-items: center;
      color: rgba(255,255,255,0.65); font-size: 0.82rem;
    }
    .trust-row span { display: flex; align-items: center; gap: 4px; }

    /* ── FORMULARIO ── */
    .form-card {
      background: #fff; border-radius: 20px; padding: 32px 28px;
      box-shadow: 0 20px 60px rgba(7,26,62,0.3);
    }
    .form-card h2 {
      font-family: var(--font-d); font-size: 1.4rem; color: var(--azul);
      margin-bottom: 8px;
    }
    .form-card .form-sub { color: var(--muted); font-size: 0.88rem; margin-bottom: 20px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
    .form-group label { font-size: 0.82rem; font-weight: 600; color: var(--azul); }
    .form-group input,
    .form-group select {
      padding: 12px 16px; border: 1.5px solid #D1DBE8; border-radius: 10px;
      font-family: var(--font-b); font-size: 0.95rem; color: var(--azul);
      background: #fff; transition: border-color 0.2s; width: 100%;
    }
    .form-group input:focus,
    .form-group select:focus { outline: none; border-color: var(--acento); }
    .form-group input.error,
    .form-group select.error { border-color: #E53E3E; }
    .form-error { font-size: 0.75rem; color: #E53E3E; margin-top: 4px; display: none; }
    .form-submit { width: 100%; margin-top: 4px; font-size: 1rem; padding: 15px; }
    .form-microcopy { text-align: center; color: var(--muted); font-size: 0.78rem; margin-top: 10px; }

    /* ── TRUST STRIP ── */
    .trust-strip {
      background: var(--azul-med); padding: 20px 0;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .trust-strip .wrap {
      display: flex; flex-wrap: wrap; gap: 0;
      justify-content: space-around; align-items: center;
    }
    .trust-item {
      text-align: center; padding: 8px 20px;
      border-right: 1px solid rgba(255,255,255,0.12);
      flex: 1; min-width: 120px;
    }
    .trust-item:last-child { border-right: none; }
    .trust-num { font-family: var(--font-d); font-size: 1.5rem; font-weight: 700; color: #fff; }
    .trust-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-top: 2px; }

    /* ── SECCIONES GENERALES ── */
    section { padding: 72px 0; }
    .section-eyebrow {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.16em;
      text-transform: uppercase; color: var(--acento); margin-bottom: 12px; display: block;
    }
    .section-title {
      font-family: var(--font-d); font-size: clamp(1.6rem, 3.5vw, 2.2rem);
      color: var(--azul); line-height: 1.2; margin-bottom: 40px;
    }
    .section-title.white { color: #fff; }
    .text-center { text-align: center; }

    /* ── DOLORES ── */
    .pain { background: var(--crema); }
    .pain-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; margin-bottom: 40px; }
    .pain-card {
      background: #fff; border-radius: var(--radius); padding: 20px 22px;
      border: 1.5px solid #E2EAF4;
      font-size: 0.95rem; font-weight: 500; color: var(--azul);
      display: flex; align-items: center; gap: 12px;
    }
    .pain-icon { font-size: 1.4rem; flex-shrink: 0; }

    /* ── QUÉ INCLUYE ── */
    .incluye { background: var(--azul); }
    .check-list { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-bottom: 40px; }
    .check-list li {
      display: flex; align-items: center; gap: 14px;
      color: rgba(255,255,255,0.9); font-size: 1.02rem; font-weight: 500;
    }
    .check-icon {
      width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      background: rgba(58,143,224,0.2); border: 1.5px solid rgba(58,143,224,0.4);
      display: flex; align-items: center; justify-content: center;
      color: var(--acento); font-size: 0.85rem; font-weight: 700;
    }

    /* ── POR QUÉ JARMAR ── */
    .porq { background: var(--crema); }
    .porq-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    .porq-card {
      background: #fff; border-radius: var(--radius); padding: 28px 22px;
      border: 1.5px solid #E2EAF4; text-align: center;
      box-shadow: var(--shadow);
    }
    .porq-emoji { font-size: 2rem; margin-bottom: 12px; }
    .porq-card p { font-size: 0.95rem; font-weight: 500; color: var(--azul); }

    /* ── TESTIMONIOS ── */
    .testi { background: var(--azul-med); }
    .testi-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    .testi-card {
      background: rgba(255,255,255,0.07); border-radius: var(--radius); padding: 24px 20px;
      border: 1px solid rgba(255,255,255,0.1);
    }
    .testi-stars { color: #F6AD55; font-size: 0.9rem; margin-bottom: 10px; }
    .testi-quote { color: rgba(255,255,255,0.85); font-size: 0.93rem; line-height: 1.55; margin-bottom: 12px; font-style: italic; }
    .testi-name { color: var(--acento); font-size: 0.8rem; font-weight: 600; }

    /* ── UBICACIÓN ── */
    .ubicacion { background: var(--crema); }
    .ubicacion-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
    .ubicacion-info { }
    .info-row { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; }
    .info-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 2px; }
    .info-row p { font-size: 0.95rem; color: var(--azul); line-height: 1.5; }
    .info-row strong { display: block; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 2px; }
    .map-embed { border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
    .map-embed iframe { width: 100%; height: 280px; border: none; display: block; }

    /* ── FAQ ── */
    .faq { background: #fff; }
    .faq-list { display: flex; flex-direction: column; gap: 0; }
    .faq-item { border-bottom: 1px solid #E2EAF4; }
    .faq-item:first-child { border-top: 1px solid #E2EAF4; }
    .faq-q {
      width: 100%; text-align: left; background: none; border: none; cursor: pointer;
      padding: 18px 0; display: flex; justify-content: space-between; align-items: center;
      font-family: var(--font-b); font-size: 1rem; font-weight: 600; color: var(--azul);
      gap: 16px;
    }
    .faq-q .faq-chevron { font-size: 1.2rem; color: var(--acento); transition: transform 0.25s; flex-shrink: 0; }
    .faq-item.open .faq-chevron { transform: rotate(45deg); }
    .faq-a { display: none; padding: 0 0 16px; color: #4A5568; font-size: 0.95rem; line-height: 1.6; }
    .faq-item.open .faq-a { display: block; }

    /* ── CTA FINAL ── */
    .cta-final {
      background: var(--grad); padding: 80px 0; text-align: center;
    }
    .cta-final h2 { font-family: var(--font-d); font-size: clamp(1.8rem,4vw,2.6rem); color: #fff; margin-bottom: 12px; }
    .cta-final p { color: rgba(255,255,255,0.7); font-size: 1.05rem; margin-bottom: 36px; max-width: 46ch; margin-inline: auto; }
    .cta-final .btn-group { justify-content: center; }

    /* ── FOOTER MÍNIMO ── */
    .lp-footer {
      background: var(--azul); padding: 28px 0; text-align: center;
    }
    .lp-footer img { height: 32px; width: auto; margin: 0 auto 10px; opacity: 0.8; }
    .lp-footer p { color: var(--muted); font-size: 0.78rem; }

    /* ── WA FLOTANTE ── */
    .wa-fab {
      position: fixed; bottom: 24px; right: 24px; z-index: 999;
      width: 58px; height: 58px; border-radius: 50%;
      background: var(--verde-wa); color: #fff;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 6px 24px rgba(37,211,102,0.45);
      transition: var(--trans); border: none; cursor: pointer; text-decoration: none;
    }
    .wa-fab:hover { transform: scale(1.1); }
    .wa-fab svg { width: 30px; height: 30px; }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .hero .wrap { grid-template-columns: 1fr; gap: 32px; }
      .pain-grid { grid-template-columns: 1fr; }
      .porq-grid { grid-template-columns: 1fr; }
      .testi-grid { grid-template-columns: 1fr; }
      .ubicacion-inner { grid-template-columns: 1fr; }
      .trust-strip .wrap { gap: 8px; }
      .trust-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); padding: 10px; }
      .trust-item:last-child { border-bottom: none; }
      .lp-tel { display: none; }
      section { padding: 52px 0; }
    }
  </style>
</head>
<body>

  <!-- ═══ HEADER MÍNIMO ═══ -->
  <header class="lp-header">
    <div class="wrap">
      <a href="/">
        <img src="/Logo BlancoEsp.png" alt="Ópticas Jarmar" />
      </a>
      <div class="lp-header-right">
        <a href="tel:+526645791970" class="lp-tel">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/></svg>
          (664) 579 1970
        </a>
        <a href="#formulario" class="btn-primary sm">Agendar cita</a>
      </div>
    </div>
  </header>

  <!-- ═══ HERO + FORMULARIO ═══ -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-copy">
        <span class="hero-eyebrow">Óptica en Zona Río · Tijuana</span>
        <h1>Examen de la vista en Tijuana</h1>
        <p class="hero-sub">Estudio visual completo. 60 años de experiencia.</p>
        <div class="hero-chip">✓ Primera valoración sin costo</div>
        <div class="trust-row">
          <span>★ 4.9 Google</span>
          <span>· +60 años</span>
          <span>· Para toda la familia</span>
        </div>
      </div>

      <div class="form-card" id="formulario">
        <h2>Agenda tu cita</h2>
        <p class="form-sub">Respuesta en minutos por WhatsApp</p>
        <form id="agendaForm" novalidate>
          <div class="form-group">
            <label for="nombre">Nombre</label>
            <input type="text" id="nombre" name="nombre" placeholder="Tu nombre completo" autocomplete="name" />
            <span class="form-error" id="nombreError">Ingresa tu nombre (mínimo 2 caracteres)</span>
          </div>
          <div class="form-group">
            <label for="tel">Teléfono / WhatsApp</label>
            <input type="tel" id="tel" name="tel" placeholder="10 dígitos" autocomplete="tel" inputmode="numeric" />
            <span class="form-error" id="telError">Ingresa 10 dígitos</span>
          </div>
          <div class="form-group">
            <label for="motivo">¿Qué necesitas?</label>
            <select id="motivo" name="motivo">
              <option value="Examen general">Examen general</option>
              <option value="Examen para niños">Examen para niños</option>
              <option value="Renovar mis lentes">Renovar mis lentes</option>
              <option value="Molestias o dolor de cabeza">Molestias o dolor de cabeza</option>
              <option value="Lentes de contacto">Lentes de contacto</option>
              <option value="Otro">Otro</option>
            </select>
          </div>
          <button type="submit" class="btn-primary form-submit">
            Agendar mi examen →
          </button>
          <p class="form-microcopy">Sin costo ni compromiso · Lun a Sáb</p>
        </form>
      </div>
    </div>
  </section>

  <!-- ═══ TRUST STRIP ═══ -->
  <div class="trust-strip">
    <div class="wrap">
      <div class="trust-item">
        <div class="trust-num">+60</div>
        <div class="trust-label">años de experiencia</div>
      </div>
      <div class="trust-item">
        <div class="trust-num">4.9★</div>
        <div class="trust-label">calificación Google</div>
      </div>
      <div class="trust-item">
        <div class="trust-num">Fam.</div>
        <div class="trust-label">Para toda la familia</div>
      </div>
      <div class="trust-item">
        <div class="trust-num">100%</div>
        <div class="trust-label">garantía de adaptación</div>
      </div>
    </div>
  </div>

  <!-- ═══ DOLORES ═══ -->
  <section class="pain">
    <div class="wrap">
      <div class="text-center">
        <span class="section-eyebrow">¿Te identificas?</span>
        <h2 class="section-title">¿Cuándo revisaste tu vista por última vez?</h2>
      </div>
      <div class="pain-grid">
        <div class="pain-card">Dolores de cabeza frente a la pantalla</div>
        <div class="pain-card">Lentes que nunca te quedaron</div>
        <div class="pain-card">Diabetes o glaucoma sin revisar este año</div>
        <div class="pain-card">¿Quieres conocer el estado de tus ojos?</div>
        <div class="pain-card">Tu hijo no ve bien el pizarrón</div>
      </div>
      <div class="text-center">
        <a href="#formulario" class="btn-primary">Agendar mi examen →</a>
      </div>
    </div>
  </section>

  <!-- ═══ QUÉ INCLUYE ═══ -->
  <section class="incluye">
    <div class="wrap-sm">
      <span class="section-eyebrow" style="color:var(--acento)">El examen</span>
      <h2 class="section-title white">Un examen completo en 30–45 min</h2>
      <ul class="check-list">
        <li><span class="check-icon">✓</span>Graduación exacta</li>
        <li><span class="check-icon">✓</span>Presión ocular (glaucoma)</li>
        <li><span class="check-icon">✓</span>Fondo de ojo (retina)</li>
        <li><span class="check-icon">✓</span>Atención para toda la familia</li>
        <li><span class="check-icon">✓</span>Aprende sobre tus ojos y buenos hábitos</li>
        <li><span class="check-icon">✓</span>Asesoría de lentes sin compromiso</li>
      </ul>
      <div class="btn-group">
