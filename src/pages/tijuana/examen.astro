  <script>
    // ── FORMULARIO → WHATSAPP ──
    const form = document.getElementById('agendaForm');
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const nombre = document.getElementById('nombre');
      const tel    = document.getElementById('tel');
      const motivo = document.getElementById('motivo');
      let ok = true;

      // Validar nombre
      const nombreErr = document.getElementById('nombreError');
      if (nombre.value.trim().length < 2) {
        nombre.classList.add('error');
        nombreErr.style.display = 'block';
        ok = false;
      } else {
        nombre.classList.remove('error');
        nombreErr.style.display = 'none';
      }

      // Validar teléfono (10 dígitos)
      const telErr = document.getElementById('telError');
      const telVal = tel.value.replace(/\D/g, '');
      if (telVal.length !== 10) {
        tel.classList.add('error');
        telErr.style.display = 'block';
        ok = false;
      } else {
        tel.classList.remove('error');
        telErr.style.display = 'none';
      }

      if (!ok) return;

      // Conversión Google Ads — descomenta cuando tengas los IDs
