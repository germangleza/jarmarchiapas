---
// Landing de campaña: Examen de la Vista Tijuana
// Ruta: /tijuana/examen
// Tráfico: Google Ads — sin menú, sin links de fuga
---
<!DOCTYPE html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="shortcut icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  <title>Examen de la Vista en Tijuana | Ópticas Jarmar · Zona Río</title>
  <meta name="description" content="Examen de la vista completo en Tijuana con equipo de precisión. 60 años de experiencia. Agenda hoy tu cita en Zona Río." />
  <!-- No index: landing de pago, no queremos tráfico orgánico duplicado -->
  <meta name="robots" content="noindex, nofollow" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-17977352986"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-17977352986');
  </script>

  <style>
    :root {
      --azul:      #071A3E;
      --azul-med:  #0D2B6B;
      --azul-vivo: #1A5BB5;
      --acento:    #3A8FE0;
      --blanco:    #FFFFFF;
      --crema:     #F4F8FF;
      --muted:     #8899AA;
      --verde-wa:  #25D366;
      --grad:      linear-gradient(135deg, #071A3E 0%, #0D2B6B 55%, #1A5BB5 100%);
      --grad-btn:  linear-gradient(135deg, #1A5BB5 0%, #3A8FE0 100%);
      --trans:     all 0.3s cubic-bezier(0.4,0,0.2,1);
      --radius:    14px;
      --shadow:    0 4px 24px rgba(7,26,62,0.18);
      --font-d:    'Playfair Display', Georgia, serif;
      --font-b:    'DM Sans', system-ui, sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } * { transition: none !important; animation: none !important; } }
    body { font-family: var(--font-b); color: var(--azul); background: var(--crema); -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }
    :focus-visible { outline: 2px solid var(--acento); outline-offset: 3px; }

    /* ── CONTAINER ── */
    .wrap { max-width: 1340px; margin: 0 auto; padding: 0 20px; }
    .wrap-sm { max-width: 600px; margin: 0 auto; padding: 0 20px; }

    /* ── HEADER MÍNIMO ── */
    .lp-header {
      background: var(--azul);
      padding: 16px 0;
      position: sticky; top: 0; z-index: 100;
      box-shadow: 0 2px 16px rgba(7,26,62,0.3);
      overflow: hidden;
    }
    .lp-header .wrap { position: relative; z-index: 1; }
    .lp-header .wrap {
      display: flex; align-items: center; justify-content: space-between;
    }
    .lp-header img { height: 40px; width: auto; }
    .lp-header-right { display: flex; align-items: center; gap: 16px; }
    .lp-tel {
      color: rgba(255,255,255,0.75); font-size: 0.88rem; font-weight: 500;
      display: flex; align-items: center; gap: 6px;
    }
    .lp-tel:hover { color: #fff; }

    /* ── BOTONES ── */
    .btn-primary {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: var(--grad-btn); color: #fff;
      padding: 14px 28px; border-radius: 100px;
      font-family: var(--font-b); font-size: 1rem; font-weight: 700;
      border: none; cursor: pointer; transition: var(--trans);
      box-shadow: 0 4px 20px rgba(58,143,224,0.35);
      text-decoration: none;
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(58,143,224,0.45); }
    .btn-primary.sm { padding: 11px 22px; font-size: 0.9rem; }

    .btn-wa {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: var(--verde-wa); color: #fff;
      padding: 14px 28px; border-radius: 100px;
      font-family: var(--font-b); font-size: 1rem; font-weight: 700;
      border: none; cursor: pointer; transition: var(--trans);
      box-shadow: 0 4px 20px rgba(37,211,102,0.3);
      text-decoration: none;
    }
    .btn-wa:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(37,211,102,0.4); }
    .btn-wa.sm { padding: 11px 22px; font-size: 0.9rem; }
    .btn-wa.outline {
      background: transparent; border: 2px solid var(--verde-wa); color: var(--verde-wa);
      box-shadow: none;
    }
    .btn-wa.outline:hover { background: rgba(37,211,102,0.08); }

    .btn-ghost {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: transparent; color: #fff;
      padding: 13px 26px; border-radius: 100px; border: 2px solid rgba(255,255,255,0.4);
      font-family: var(--font-b); font-size: 1rem; font-weight: 600;
      cursor: pointer; transition: var(--trans); text-decoration: none;
    }
    .btn-ghost:hover { border-color: #fff; background: rgba(255,255,255,0.08); }

    .btn-group { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }

    /* ── HERO ── */
    .hero {
      position: relative;
      background: url('/IMG-1925.JPG') center/cover no-repeat;
      padding: 96px 0 80px;
      min-height: 580px;
      display: flex; align-items: center;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(120deg, rgba(7,26,62,0.88) 0%, rgba(7,26,62,0.70) 60%, rgba(7,26,62,0.40) 100%);
    }
    /* ── HEX EN INCLUYE ── */
    .incluye { position: relative; }
    .incluye .hex-bg { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 0; }
    .incluye .hex-bg svg { position: absolute; }
    .incluye .hex-1  { top: 6%;  left: 3%;   opacity: 0.07; animation: float 10s ease-in-out infinite; }
    .incluye .hex-2  { top: 20%; right: 8%;  opacity: 0.06; animation: float 13s ease-in-out infinite reverse; }
    .incluye .hex-3  { top: 60%; left: 12%;  opacity: 0.05; animation: float 11s ease-in-out infinite 2s; }
    .incluye .hex-4  { top: 75%; right: 5%;  opacity: 0.08; animation: float 9s ease-in-out infinite 1s; }
    .incluye .hex-5  { top: 40%; left: 55%;  opacity: 0.04; animation: float 14s ease-in-out infinite 3s; }
    .incluye .hex-6  { top: 10%; right: 30%; opacity: 0.05; animation: float 12s ease-in-out infinite 0.5s; }
    .incluye .wrap-sm { position: relative; z-index: 1; }
    .hero .wrap {
      position: relative; z-index: 2;
      display: flex; flex-direction: column; align-items: flex-start;
      max-width: 1340px; width: 100%; margin: 0 auto; padding: 0 20px;
    }
    .hero-eyebrow {
      display: inline-block;
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--acento);
      background: rgba(58,143,224,0.15); border: 1px solid rgba(58,143,224,0.3);
      padding: 5px 14px; border-radius: 100px; margin-bottom: 20px;
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.1s;
    }
    .hero h1 {
      font-family: var(--font-d);
      font-size: clamp(2.2rem, 4.5vw, 3.4rem);
      color: #fff; line-height: 1.12; margin-bottom: 18px;
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.2s;
    }
    .hero-sub {
      color: rgba(255,255,255,0.82); font-size: 1.08rem; margin-bottom: 24px; max-width: 580px; line-height: 1.65;
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.3s;
    }
    .hero-chips {
      display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 28px;
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.4s;
    }
    .hero-chip {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(58,143,224,0.15); border: 1px solid rgba(58,143,224,0.3);
      color: #fff; font-size: 0.82rem; font-weight: 600;
      padding: 6px 14px; border-radius: 100px;
    }
    .hero-ctas {
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.5s;
    }
    /* ── REVIEW BADGE ── */
    .hero-review {
      display: flex; align-items: center; gap: 12px; margin-top: 28px;
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.6s;
    }
    .review-avatars {
      display: flex;
    }
    .review-avatars img {
      width: 36px; height: 36px; border-radius: 50%;
      border: 2px solid #fff; object-fit: cover;
      margin-left: -10px;
    }
    .review-avatars img:first-child { margin-left: 0; }
    .review-text { display: flex; flex-direction: column; gap: 2px; }
    .review-stars { color: #F6AD55; font-size: 0.9rem; letter-spacing: 1px; }
    .review-label { color: rgba(255,255,255,0.75); font-size: 0.8rem; font-weight: 500; }
    /* ── FADE IN ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── FORMULARIO ── */
    .form-card {
      background: #fff; border-radius: 20px; padding: 32px 28px;
      box-shadow: 0 20px 60px rgba(7,26,62,0.3);
    }
    .form-card h2 {
      font-family: var(--font-d); font-size: 1.4rem; color: var(--azul);
      margin-bottom: 8px;
    }
    .form-card .form-sub { color: var(--muted); font-size: 0.88rem; margin-bottom: 20px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
    .form-group label { font-size: 0.82rem; font-weight: 600; color: var(--azul); }
    .form-group input,
    .form-group select {
      padding: 12px 16px; border: 1.5px solid #D1DBE8; border-radius: 10px;
      font-family: var(--font-b); font-size: 0.95rem; color: var(--azul);
      background: #fff; transition: border-color 0.2s; width: 100%;
    }
    .form-group input:focus,
    .form-group select:focus { outline: none; border-color: var(--acento); }
    .form-group input.error,
    .form-group select.error { border-color: #E53E3E; }
    .form-error { font-size: 0.75rem; color: #E53E3E; margin-top: 4px; display: none; }
    .form-submit { width: 100%; margin-top: 4px; font-size: 1rem; padding: 15px; }
    .form-microcopy { text-align: center; color: var(--muted); font-size: 0.78rem; margin-top: 10px; }


    /* ── SECCIONES GENERALES ── */
    section { padding: 72px 0; }
    .section-eyebrow {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.16em;
      text-transform: uppercase; color: var(--acento); margin-bottom: 12px; display: block;
    }
    .section-title {
      font-family: var(--font-d); font-size: clamp(1.6rem, 3.5vw, 2.2rem);
      color: var(--azul); line-height: 1.2; margin-bottom: 40px;
    }
    .section-title.white { color: #fff; }
    .text-center { text-align: center; }

    /* ── DOLORES ── */
    .pain {
      position: relative;
      background: url('/ATENCION.jpg') center/cover no-repeat;
    }
    .pain::before {
      content: '';
      position: absolute; inset: 0;
      background: rgba(7, 26, 62, 0.70);
    }
    .pain .wrap { position: relative; z-index: 1; }
    .pain .section-eyebrow { color: rgba(255,255,255,0.75); }
    .pain .section-title { color: #fff; }
    .pain-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; margin-bottom: 40px; }
    .pain-card {
      background: rgba(255,255,255,0.12); border-radius: var(--radius); padding: 20px 22px;
      border: 1.5px solid rgba(255,255,255,0.2);
      font-size: 0.95rem; font-weight: 500; color: #fff;
      display: flex; align-items: center; gap: 12px;
      backdrop-filter: blur(8px);
    }
    .pain-icon { font-size: 1.4rem; flex-shrink: 0; }

    /* ── QUÉ INCLUYE ── */
    .incluye { background: var(--azul); }
    .check-list { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-bottom: 40px; }
    .check-list li {
      display: flex; align-items: center; gap: 14px;
      color: rgba(255,255,255,0.9); font-size: 1.02rem; font-weight: 500;
    }
    .check-icon {
      width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      background: rgba(58,143,224,0.2); border: 1.5px solid rgba(58,143,224,0.4);
      display: flex; align-items: center; justify-content: center;
      color: var(--acento); font-size: 0.85rem; font-weight: 700;
    }

    /* ── POR QUÉ JARMAR ── */
    .porq {
      position: relative;
      background: url('/IMG-1929.JPG') center/cover no-repeat;
    }
    .porq::before {
      content: '';
      position: absolute; inset: 0;
      background: rgba(7, 26, 62, 0.72);
    }
    .porq .wrap { position: relative; z-index: 1; }
    .porq .section-eyebrow { color: rgba(255,255,255,0.75); }
    .porq .section-title { color: #fff; }
    .porq-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    .porq-card {
      background: rgba(255,255,255,0.12); border-radius: var(--radius); padding: 28px 22px;
      border: 1.5px solid rgba(255,255,255,0.2); text-align: center;
      backdrop-filter: blur(8px);
    }
    .porq-card p { font-size: 0.95rem; font-weight: 500; color: #fff; }

    /* ── TESTIMONIOS / PACIENTES ── */
    .pacientes {
      --p-fondo:   var(--crema, #F4F8FF);
      --p-tarjeta: #FFFFFF;
      --p-tinta:   var(--azul, #071A3E);
      --p-tinta-2: #5A6273;
      --p-linea:   #E3E6EB;
      --p-acento:  var(--acento, #3A8FE0);
      background: var(--p-fondo);
      padding: clamp(56px, 9vw, 104px) 0;
    }
    .pacientes__wrap { max-width: 1120px; margin-inline: auto; padding-inline: 20px; }

    .pacientes__head { margin-bottom: clamp(32px, 5vw, 56px); max-width: 44ch; }
    .rating { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
    .rating__num   { font-size: 1.25rem; font-weight: 700; color: var(--p-tinta); font-variant-numeric: tabular-nums; }
    .rating__stars { color: #F6AD55; letter-spacing: .08em; font-size: .95rem; }
    .rating__src   { display: inline-flex; align-items: center; gap: 5px; font-size: .75rem; color: var(--p-tinta-2); text-transform: uppercase; letter-spacing: .08em; }
    .pacientes__head h2 {
      font-family: var(--font-d);
      font-size: clamp(1.6rem, 3.4vw, 2.4rem);
      line-height: 1.15; letter-spacing: -.02em;
      color: var(--p-tinta); margin: 0 0 8px;
    }
    .pacientes__sub { color: var(--p-tinta-2); font-size: 1rem; margin: 0; }

    .rese-lista {
      list-style: none; margin: 0; padding: 0;
      display: grid; gap: 16px;
      grid-template-columns: repeat(2, 1fr);
    }
    @media (max-width: 760px) {
      .rese-lista {
        grid-auto-flow: column;
        grid-auto-columns: 82%;
        grid-template-columns: none;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-padding-inline: 20px;
        margin-inline: -20px;
        padding-inline: 20px;
        padding-bottom: 8px;
        scrollbar-width: none;
        overscroll-behavior-x: contain;
      }
      .rese-lista::-webkit-scrollbar { display: none; }
      .rese { scroll-snap-align: start; }
    }

    .rese__card {
      height: 100%; margin: 0;
      display: flex; flex-direction: column; gap: 14px;
      background: var(--p-tarjeta);
      border: 1px solid var(--p-linea);
      border-radius: 6px;
      padding: clamp(22px, 3vw, 30px);
      transition: border-color 220ms cubic-bezier(.4,0,.2,1), transform 220ms cubic-bezier(.4,0,.2,1);
    }
    @media (hover: hover) {
      .rese:hover .rese__card { border-color: var(--p-tinta); transform: translateY(-2px); }
    }

    .rese__hook {
      font-size: clamp(1.1rem, 2vw, 1.4rem);
      line-height: 1.3; font-weight: 600; letter-spacing: -.015em;
      color: var(--p-tinta); margin: 0;
    }
    .rese__hook::before { content: "\201C"; color: var(--p-acento); margin-right: 2px; }

    .rese__full {
      font-size: .9375rem; line-height: 1.6;
      color: var(--p-tinta-2); margin: 0; flex: 1;
    }

    .rese__pie {
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center; gap: 4px 10px;
      padding-top: 14px;
      border-top: 1px solid var(--p-linea);
    }
    .rese__mono {
      grid-row: span 2;
      width: 34px; height: 34px;
      display: grid; place-items: center;
      border-radius: 50%;
      background: rgba(58,143,224,0.14);
      color: var(--p-tinta);
      font-weight: 700; font-size: .8125rem;
    }
    .rese__quien { font-style: normal; font-weight: 600; font-size: .875rem; color: var(--p-tinta); }
    .rese__fuente {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: .75rem; color: var(--p-tinta-2);
    }

    .rese__ver-todas {
      display: inline-flex; align-items: center; gap: 8px;
      margin-top: 28px;
      font-size: .9375rem; font-weight: 600;
      color: var(--p-tinta);
      text-decoration: none;
      border-bottom: 1px solid var(--p-linea);
      padding-bottom: 3px;
      transition: border-color 200ms cubic-bezier(.4,0,.2,1);
    }
    .rese__ver-todas:hover { border-color: var(--p-acento); }
    .rese__ver-todas .arrow { transition: transform 200ms cubic-bezier(.4,0,.2,1); display: inline-block; }
    .rese__ver-todas:hover .arrow { transform: translateX(4px); }

    .pacientes a:focus-visible,
    .rese-lista:focus-visible { outline: 2px solid var(--p-acento); outline-offset: 3px; border-radius: 4px; }

    /* ── REVEAL: de borroso a claro ── */
    .reveal {
      opacity: 0; filter: blur(5px); transform: translateY(14px);
      transition:
        opacity   600ms cubic-bezier(.22,1,.36,1),
        filter    600ms cubic-bezier(.22,1,.36,1),
        transform 600ms cubic-bezier(.22,1,.36,1);
      transition-delay: calc(var(--i, 0) * 90ms);
    }
    .reveal.is-in { opacity: 1; filter: blur(0); transform: none; }
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; filter: none; transform: none; transition: none; }
      .rese-lista { scroll-behavior: auto; }
      .rese__card, .rese__ver-todas .arrow { transition: none; }
    }

    /* ── UBICACIÓN ── */
    .ubicacion { background: var(--crema); }
    .ubicacion-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
    .ubicacion-info { }
    .info-row { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; }
    .info-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 2px; }
    .info-row p { font-size: 0.95rem; color: var(--azul); line-height: 1.5; }
    .info-row strong { display: block; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 2px; }
    .map-embed { border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
    .map-embed iframe { width: 100%; height: 280px; border: none; display: block; }

    /* ── FAQ ── */
    .faq { background: var(--azul); }
    .faq .section-title { color: #fff; }
    .faq-list { display: flex; flex-direction: column; gap: 0; }
    .faq-item { border-bottom: 1px solid rgba(255,255,255,0.12); }
    .faq-item:first-child { border-top: 1px solid rgba(255,255,255,0.12); }
    .faq-q {
      width: 100%; text-align: left; background: none; border: none; cursor: pointer;
      padding: 20px 0; display: flex; justify-content: space-between; align-items: center;
      font-family: var(--font-b); font-size: 1rem; font-weight: 600; color: #fff;
      gap: 16px;
    }
    .faq-q .faq-chevron { font-size: 1.3rem; color: var(--acento); transition: transform 0.25s; flex-shrink: 0; }
    .faq-item.open .faq-chevron { transform: rotate(45deg); }
    .faq-a { display: none; padding: 0 0 18px; color: rgba(255,255,255,0.72); font-size: 0.97rem; line-height: 1.65; }
    .faq-item.open .faq-a { display: block; }

    /* ── CTA FINAL ── */
    .cta-final {
      background: var(--grad); padding: 80px 0; text-align: center;
    }
    .cta-final h2 { font-family: var(--font-d); font-size: clamp(1.8rem,4vw,2.6rem); color: #fff; margin-bottom: 12px; }
    .cta-final p { color: rgba(255,255,255,0.7); font-size: 1.05rem; margin-bottom: 36px; max-width: 46ch; margin-inline: auto; }
    .cta-final .btn-group { justify-content: center; }

    /* ── FOOTER MÍNIMO ── */
    .lp-footer {
      background: var(--azul); padding: 28px 0; text-align: center;
    }
    .lp-footer img { height: 32px; width: auto; margin: 0 auto 10px; opacity: 0.8; }
    .lp-footer p { color: var(--muted); font-size: 0.78rem; }


    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
